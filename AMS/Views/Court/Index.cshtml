@model IEnumerable<AMS.Models.Court>

@{
    ViewData["Title"] = "Courts";
}

<div class="max-w-7xl mx-auto space-y-8">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
            <h1 class="text-4xl font-bold text-white">Courts</h1>
            <p class="text-slate-400 mt-1">Manage all courts and their jurisdictions</p>
        </div>

        <button onclick="showCreateModal()"
                class="px-6 py-3 bg-emerald-600 hover:bg-emerald-500 transition-all rounded-2xl font-semibold flex items-center gap-3 text-lg shadow-lg shadow-emerald-500/30">
            <i class="fas fa-plus"></i>
            Add New Court
        </button>
    </div>

    <!-- Filters & Search -->
    <div class="bg-slate-900 border border-slate-700 rounded-3xl p-6 flex flex-col md:flex-row gap-4">
        <div class="flex-1">
            <input type="text" id="searchInput"
                   onkeyup="filterTable()"
                   class="w-full bg-slate-800 border border-slate-700 focus:border-emerald-500 rounded-2xl py-4 px-6 text-white placeholder-slate-400 focus:outline-none"
                   placeholder="Search by court name or location...">
        </div>

        <div class="flex gap-3">
            <select id="typeFilter" onchange="filterTable()"
                    class="bg-slate-800 border border-slate-700 rounded-2xl py-4 px-6 text-white focus:outline-none focus:border-emerald-500">
                <option value="">All Types</option>
                <option value="High Court">High Court</option>
                <option value="Session Court">Session Court</option>
                <option value="District Court">District Court</option>
                <option value="Magistrate Court">Magistrate Court</option>
            </select>
        </div>
    </div>

    <!-- Courts Table -->
    <div class="bg-slate-900 border border-slate-700 rounded-3xl overflow-hidden">
        <table class="w-full" id="courtsTable">
            <thead>
                <tr class="border-b border-slate-700 text-slate-400 text-sm">
                    <th class="text-left py-6 px-8 font-medium">Court Name</th>
                    <th class="text-left py-6 px-8 font-medium">Court Type</th>
                    <th class="text-left py-6 px-8 font-medium">Location</th>
                    <th class="text-left py-6 px-8 font-medium">Total Hearings</th>
                    <th class="text-right py-6 px-8 font-medium">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-800 text-slate-300">
                @if (Model != null && Model.Any())
                {
                    @foreach (var court in Model)
                    {
                        <tr class="hover:bg-slate-800/70 transition-all group">
                            <td class="py-6 px-8 font-medium">@court.CourtName</td>
                            <td class="py-6 px-8">
                                <span class="px-5 py-2 text-xs font-semibold rounded-2xl
                                            @(court.CourtType == "High Court" ? "bg-violet-500/20 text-violet-400" :
                                                                            court.CourtType == "Session Court" ? "bg-amber-500/20 text-amber-400" : "bg-sky-500/20 text-sky-400")">
                            @court.CourtType
                        </span>
                    </td>
                    <td class="py-6 px-8">@court.Location</td>
                    <td class="py-6 px-8">
                        <span class="text-emerald-400 font-semibold">@(court.Hearings?.Count ?? 0)</span>
                    </td>
                    <td class="py-6 px-8 text-right">
                        <div class="flex justify-end gap-3 opacity-70 group-hover:opacity-100 transition-all">
                            <button onclick="viewHearings(@court.Id)"
                                    class="p-3 hover:bg-slate-700 rounded-xl text-sky-400">
                                <i class="fas fa-calendar-alt"></i>
                            </button>
                            <button onclick="editCourt(@court.Id)"
                                    class="p-3 hover:bg-slate-700 rounded-xl text-amber-400">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button onclick="deleteCourt(@court.Id)"
                                    class="p-3 hover:bg-slate-700 rounded-xl text-rose-400">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                                }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="py-20 text-center text-slate-400">
                            <i class="fas fa-gavel text-5xl mb-4 opacity-30"></i>
                            <p class="text-xl">No courts found</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create/Edit Modal -->
<div id="courtModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center z-50">
    <div class="bg-slate-900 border border-slate-700 rounded-3xl w-full max-w-lg mx-4">
        <div class="p-8">
            <h2 id="modalTitle" class="text-2xl font-semibold mb-6">Add New Court</h2>

            <form id="courtForm">
                <input type="hidden" id="courtId" />

                <div class="space-y-6">
                    <div>
                        <label class="block text-sm text-slate-400 mb-2">Court Name</label>
                        <input type="text" id="courtName" required
                               class="w-full bg-slate-800 border border-slate-700 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-emerald-500">
                    </div>

                    <div>
                        <label class="block text-sm text-slate-400 mb-2">Court Type</label>
                        <select id="courtType" required
                                class="w-full bg-slate-800 border border-slate-700 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-emerald-500">
                            <option value="">Select Type</option>
                            <option value="High Court">High Court</option>
                            <option value="Session Court">Session Court</option>
                            <option value="District Court">District Court</option>
                            <option value="Magistrate Court">Magistrate Court</option>
                            <option value="Supreme Court">Supreme Court</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm text-slate-400 mb-2">Location</label>
                        <input type="text" id="location" required
                               class="w-full bg-slate-800 border border-slate-700 rounded-2xl px-6 py-4 text-white focus:outline-none focus:border-emerald-500">
                    </div>
                </div>
            </form>
        </div>

        <div class="border-t border-slate-700 p-6 flex gap-4">
            <button onclick="hideModal()"
                    class="flex-1 py-4 bg-slate-800 hover:bg-slate-700 transition rounded-2xl font-medium">
                Cancel
            </button>
            <button onclick="saveCourt()"
                    class="flex-1 py-4 bg-emerald-600 hover:bg-emerald-500 transition rounded-2xl font-semibold">
                Save Court
            </button>
        </div>
    </div>
</div>

<script>
    function showCreateModal() {
        document.getElementById('modalTitle').textContent = 'Add New Court';
        document.getElementById('courtForm').reset();
        document.getElementById('courtId').value = '';
        document.getElementById('courtModal').classList.remove('hidden');
    }

    function hideModal() {
        document.getElementById('courtModal').classList.add('hidden');
    }

    function saveCourt() {
        // TODO: Implement AJAX call to controller (Create/Edit)
        alert("Court saved successfully! (Implement backend call)");
        hideModal();
        location.reload(); // Temporary
    }

    function editCourt(id) {
        // TODO: Load data by ID and open modal
        alert("Edit court #" + id + " - Implement load & edit");
    }

    function deleteCourt(id) {
        if (confirm("Are you sure you want to delete this court?")) {
            // TODO: Implement delete
            alert("Court deleted (Implement backend call)");
            location.reload();
        }
    }

    function viewHearings(id) {
        window.location.href = `/Hearings?courtId=${id}`;
    }

    function filterTable() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const typeFilter = document.getElementById('typeFilter').value;
        const rows = document.querySelectorAll('#courtsTable tbody tr');

        rows.forEach(row => {
            const name = row.cells[0].textContent.toLowerCase();
            const type = row.cells[1].textContent.toLowerCase();
            const location = row.cells[2].textContent.toLowerCase();

            const matchesSearch = name.includes(search) || location.includes(search);
            const matchesType = !typeFilter || type.includes(typeFilter.toLowerCase());

            row.style.display = (matchesSearch && matchesType) ? '' : 'none';
        });
    }
</script>
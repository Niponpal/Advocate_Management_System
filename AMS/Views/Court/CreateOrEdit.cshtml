@model AMS.Models.Court

@{
    ViewData["Title"] = Model.Id == 0 ? "Add New Court" : "Edit Court";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-slate-900 border border-slate-700 rounded-3xl p-10">
        <!-- Header -->
        <div class="flex items-center gap-4 mb-10">
            <div class="w-12 h-12 bg-emerald-600 rounded-2xl flex items-center justify-center text-3xl">🏛️</div>
            <div>
                <h1 class="text-3xl font-bold text-white">@(Model.Id == 0 ? "Add New Court" : "Edit Court")</h1>
                <p class="text-slate-400">Court Information</p>
            </div>
        </div>

        <form asp-action="CreateOrEdit" method="post" class="space-y-8">
            <input type="hidden" asp-for="Id" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Court Name -->
                <div class="md:col-span-2">
                    <label asp-for="CourtName" class="block text-sm text-slate-400 mb-2"></label>
                    <input asp-for="CourtName"
                           class="w-full bg-slate-800 border border-slate-700 focus:border-emerald-500 rounded-2xl px-6 py-5 text-white focus:outline-none transition"
                           placeholder="e.g. Dhaka High Court" />
                    <span asp-validation-for="CourtName" class="text-rose-400 text-sm mt-1"></span>
                </div>

                <!-- Court Type -->
                <div>
                    <label asp-for="CourtType" class="block text-sm text-slate-400 mb-2"></label>
                    <select asp-for="CourtType"
                            class="w-full bg-slate-800 border border-slate-700 focus:border-emerald-500 rounded-2xl px-6 py-5 text-white focus:outline-none transition">
                        <option value="">-- Select Court Type --</option>
                        <option value="Supreme Court">Supreme Court</option>
                        <option value="High Court">High Court</option>
                        <option value="Session Court">Session Court</option>
                        <option value="District Court">District Court</option>
                        <option value="Magistrate Court">Magistrate Court</option>
                        <option value="Family Court">Family Court</option>
                        <option value="Labor Court">Labor Court</option>
                    </select>
                    <span asp-validation-for="CourtType" class="text-rose-400 text-sm mt-1"></span>
                </div>

                <!-- Location -->
                <div>
                    <label asp-for="Location" class="block text-sm text-slate-400 mb-2"></label>
                    <input asp-for="Location"
                           class="w-full bg-slate-800 border border-slate-700 focus:border-emerald-500 rounded-2xl px-6 py-5 text-white focus:outline-none transition"
                           placeholder="e.g. Dhaka, Bangladesh" />
                    <span asp-validation-for="Location" class="text-rose-400 text-sm mt-1"></span>
                </div>
            </div>

            <!-- Submit Buttons -->
            <div class="flex gap-4 pt-6 border-t border-slate-700">
                <a asp-action="Index"
                   class="flex-1 py-5 bg-slate-800 hover:bg-slate-700 text-center rounded-2xl font-medium transition">
                    Cancel
                </a>

                <button type="submit"
                        class="flex-1 py-5 bg-emerald-600 hover:bg-emerald-500 rounded-2xl font-semibold transition flex items-center justify-center gap-3">
                    <i class="fas fa-save"></i>
                    @(Model.Id == 0 ? "Create Court" : "Update Court")
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@model AMS.Models.Court
@{
    ViewData["Title"] = "Court Details";
}

<div class="max-w-4xl mx-auto space-y-8">
    <!-- Header -->
    <div class="flex justify-between items-start">
        <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-emerald-600 rounded-3xl flex items-center justify-center text-4xl">🏛️</div>
            <div>
                <h1 class="text-4xl font-bold text-white">@Model.CourtName</h1>
                <p class="text-emerald-400 text-xl">@Model.CourtType</p>
            </div>
        </div>

        <div class="flex gap-3">
            <a asp-action="CreateOrEdit" asp-route-id="@Model.Id"
               class="px-6 py-3 bg-amber-600 hover:bg-amber-500 transition rounded-2xl flex items-center gap-2 font-medium">
                <i class="fas fa-edit"></i> Edit
            </a>
            <a asp-action="Index"
               class="px-6 py-3 bg-slate-700 hover:bg-slate-600 transition rounded-2xl font-medium">
                ← Back to Courts
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Info Card -->
        <div class="lg:col-span-2 bg-slate-900 border border-slate-700 rounded-3xl p-8">
            <h2 class="text-2xl font-semibold mb-6 pb-4 border-b border-slate-700">Court Information</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <p class="text-slate-400 text-sm">Court Name</p>
                    <p class="text-2xl font-medium text-white mt-1">@Model.CourtName</p>
                </div>
                <div>
                    <p class="text-slate-400 text-sm">Court Type</p>
                    <p class="mt-1">
                        <span class="px-6 py-2 text-sm font-semibold rounded-2xl
                            @(Model.CourtType == "High Court" ? "bg-violet-500/20 text-violet-400" :
                                                            Model.CourtType == "Session Court" ? "bg-amber-500/20 text-amber-400" : "bg-sky-500/20 text-sky-400")">
                            @Model.CourtType
                        </span>
                    </p>
                </div>
                <div class="md:col-span-2">
                    <p class="text-slate-400 text-sm">Location</p>
                    <p class="text-xl text-white mt-1">@Model.Location</p>
                </div>
            </div>
        </div>

        <!-- Statistics Card -->
        <div class="bg-slate-900 border border-slate-700 rounded-3xl p-8">
            <h2 class="text-2xl font-semibold mb-6">Statistics</h2>
            <div class="space-y-8">
                <div class="flex justify-between items-center">
                    <div>
                        <p class="text-slate-400">Total Hearings</p>
                        <p class="text-5xl font-bold text-emerald-400 mt-2">@(Model.Hearings?.Count ?? 0)</p>
                    </div>
                    <i class="fas fa-calendar-alt text-5xl text-emerald-500/30"></i>
                </div>

                <div class="h-px bg-slate-700"></div>

                <div>
                    <p class="text-slate-400 text-sm mb-3">Recent Activity</p>
                    <p class="text-slate-300">No recent hearings recorded</p>
                    <!-- You can show latest hearings here later -->
                </div>
            </div>
        </div>
    </div>

    <!-- Hearings Section -->
    <div class="bg-slate-900 border border-slate-700 rounded-3xl p-8">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-2xl font-semibold">Upcoming & Recent Hearings</h2>
            <a asp-controller="Hearing" asp-action="Index" asp-route-courtId="@Model.Id"
               class="text-emerald-400 hover:text-emerald-300 flex items-center gap-2">
                View All Hearings <i class="fas fa-arrow-right"></i>
            </a>
        </div>

        @if (Model.Hearings != null && Model.Hearings.Any())
        {
            <div class="space-y-4">
                @foreach (var hearing in Model.Hearings.Take(5))
                {
                    <div class="flex items-center justify-between bg-slate-800/50 p-5 rounded-2xl hover:bg-slate-700 transition">
                        <div class="flex items-center gap-4">
                            <div class="text-3xl">⚖️</div>
                            <div>
                                <p class="font-medium">@hearing.Case?.CaseTitle</p>
                                <p class="text-sm text-slate-400">@hearing.HearingDate.ToString("dd MMM yyyy") • @hearing.HearingDate.ToString("hh:mm tt")</p>
                            </div>
                        </div>
                        <span class="px-5 py-2 text-xs font-semibold rounded-2xl bg-emerald-500/20 text-emerald-400">
                            @hearing.HearingStatus
                        </span>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-16 text-slate-400">
                <i class="fas fa-calendar text-6xl opacity-30 mb-4"></i>
                <p class="text-xl">No hearings scheduled yet</p>
            </div>
        }
    </div>
</div>
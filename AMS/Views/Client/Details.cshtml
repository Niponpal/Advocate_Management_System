@model AMS.Models.Client

@{
    ViewData["Title"] = "Client Details";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-300 p-8">
    <div class="max-w-5xl mx-auto space-y-8">

        <!-- Header -->
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
                <a asp-action="Index"
                   class="p-3 bg-slate-200 dark:bg-slate-800 hover:bg-slate-300 dark:hover:bg-slate-700 rounded-2xl transition">
                    <i class="fas fa-arrow-left"></i>
                </a>
                <div>
                    <h1 class="text-4xl font-bold text-slate-800 dark:text-white">Client Details</h1>
                    <p class="text-slate-500 dark:text-slate-400">ID: #@Model.Id</p>
                </div>
            </div>

            <div class="flex gap-3">
                <a asp-action="Edit" asp-route-id="@Model.Id"
                   class="px-6 py-3 bg-amber-600 hover:bg-amber-500 text-white rounded-2xl flex items-center gap-3 transition">
                    <i class="fas fa-edit"></i>
                    Edit Client
                </a>
                <button onclick="deleteClient(@Model.Id)"
                        class="px-6 py-3 bg-rose-600 hover:bg-rose-500 text-white rounded-2xl flex items-center gap-3 transition">
                    <i class="fas fa-trash"></i>
                    Delete
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <!-- Main Info Card -->
            <div class="lg:col-span-2 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-10">
                <div class="flex items-start gap-6 mb-10">
                    <div class="w-24 h-24 bg-emerald-600 rounded-3xl flex items-center justify-center text-5xl text-white shadow-inner">
                        👤
                    </div>
                    <div class="flex-1">
                        <h2 class="text-4xl font-bold text-slate-800 dark:text-white">@Model.ClientName</h2>
                        <div class="flex items-center gap-4 mt-3">
                            <span class="px-5 py-2 bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 rounded-2xl text-sm font-semibold">Active Client</span>
                            <span class="text-slate-500 dark:text-slate-400">Joined: @DateTime.Now.ToString("MMMM yyyy")</span>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Email</p>
                        <p class="text-lg font-medium">@Model.Email</p>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Phone</p>
                        <p class="text-lg font-medium">@Model.Phone</p>
                    </div>
                    <div class="md:col-span-2">
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Full Address</p>
                        <p class="text-lg leading-relaxed">@Model.Address</p>
                    </div>
                    <div>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">NID Number</p>
                        <p class="font-mono text-lg">@Model.NIDNumber</p>
                    </div>
                </div>
            </div>

            <!-- Quick Stats -->
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-8 flex flex-col">
                <h3 class="text-xl font-semibold mb-6">Quick Stats</h3>

                <div class="space-y-8 flex-1">
                    <div class="flex justify-between items-center">
                        <div class="text-slate-500 dark:text-slate-400">Total Cases</div>
                        <div class="text-4xl font-bold text-emerald-600">@(Model.Cases?.Count ?? 0)</div>
                    </div>
                    <div class="flex justify-between items-center">
                        <div class="text-slate-500 dark:text-slate-400">Total Invoices</div>
                        <div class="text-4xl font-bold text-violet-600">@(Model.Invoices?.Count ?? 0)</div>
                    </div>
                    <div class="flex justify-between items-center">
                        <div class="text-slate-500 dark:text-slate-400">Upcoming Appointments</div>
                        <div class="text-4xl font-bold text-amber-600">@(Model.Appointments?.Count ?? 0)</div>
                    </div>
                </div>

                <a asp-action="Index" class="mt-auto text-center text-emerald-600 hover:text-emerald-500 font-medium">
                    View All Related Records →
                </a>
            </div>
        </div>

        <!-- Recent Cases Section -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-10">
            <div class="flex justify-between items-center mb-8">
                <h3 class="text-2xl font-semibold">Recent Cases</h3>
                <a asp-controller="Cases" asp-action="Index" class="text-emerald-600 hover:text-emerald-500">View All Cases →</a>
            </div>

            @if (Model.Cases != null && Model.Cases.Any())
            {
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="text-sm text-slate-500 dark:text-slate-400 border-b border-slate-200 dark:border-slate-700">
                                <th class="py-5 text-left">Case ID</th>
                                <th class="py-5 text-left">Matter</th>
                                <th class="py-5 text-left">Status</th>
                                <th class="py-5 text-left">Next Hearing</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                            @foreach (var c in Model.Cases.Take(5))
                            {
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
                                    <td class="py-5 font-mono">#@c.Id</td>
                                    <td class="py-5">@c.CaseTitle</td> <!-- Assuming Case has Title property -->
                                    <td class="py-5">
                                        <span class="px-5 py-1.5 bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-400 rounded-2xl text-sm">
                                            Active
                                        </span>
                                    </td>
                                    <td class="py-5 text-sm text-slate-500">Coming soon</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-16 text-slate-400">
                    <i class="fas fa-briefcase text-5xl mb-4"></i>
                    <p>No cases found for this client yet.</p>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function deleteClient(id) {
        if (confirm('Are you sure you want to delete this client? This action cannot be undone.')) {
            // TODO: Implement delete via POST
            alert(`Client #${id} has been deleted.`);
            window.location.href = '/Clients';
        }
    }
</script>
@model IEnumerable<AMS.Models.AdvocateSchedule>
@{
    ViewData["Title"] = "Advocate Schedules";
}

<div class="p-6 lg:p-10">
    <div class="max-w-7xl mx-auto space-y-10">

        <!-- Header -->
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6">
            <div>
                <h1 class="text-4xl font-bold text-slate-900 dark:text-white">Advocate Schedules</h1>
                <p class="text-slate-500 dark:text-slate-400 mt-2 text-lg">
                    Manage all advocate availability and court schedules
                </p>
            </div>

            <a asp-action="CreateOrEdit"
               class="px-8 py-4 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white font-semibold rounded-3xl flex items-center gap-3 text-lg transition-all shadow-lg shadow-emerald-500/30 hover:shadow-xl">
                <i class="fas fa-plus"></i>
                Add New Schedule
            </a>
        </div>

        <!-- Main Table Card -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-3xl shadow-sm overflow-hidden">

            <div class="px-8 py-6 border-b border-slate-200 dark:border-slate-700 flex justify-between items-center bg-slate-50 dark:bg-slate-800">
                <h2 class="text-xl font-semibold text-slate-900 dark:text-white">All Schedules</h2>
                <div class="text-sm text-slate-500 dark:text-slate-400">
                    Total Records: <span class="font-medium text-slate-700 dark:text-slate-300">@Model.Count()</span>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-slate-50 dark:bg-slate-800">
                        <tr>
                            <th class="px-8 py-5 text-left text-sm font-medium text-slate-500 dark:text-slate-400 w-12">#</th>
                            <th class="px-8 py-5 text-left text-sm font-medium text-slate-500 dark:text-slate-400">Advocate</th>
                            <th class="px-8 py-5 text-left text-sm font-medium text-slate-500 dark:text-slate-400">Schedule Date</th>
                            <th class="px-8 py-5 text-left text-sm font-medium text-slate-500 dark:text-slate-400">Available Time</th>
                            <th class="px-8 py-5 text-center text-sm font-medium text-slate-500 dark:text-slate-400">Status</th>
                            <th class="px-8 py-5 text-center text-sm font-medium text-slate-500 dark:text-slate-400">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                        @if (Model.Any())
                        {
                            int serial = 1;
                            foreach (var item in Model)
                            {
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/60 transition-colors group">
                                    <td class="px-8 py-6 text-slate-500 dark:text-slate-400 font-medium">
                                        @serial
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="font-semibold text-slate-900 dark:text-white">
                                            @item.Advocate?.AdvocateName
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="text-slate-900 dark:text-white font-medium">
                                            @item.ScheduleDate.ToString("dd MMMM yyyy")
                                        </div>
                                        <div class="text-sm text-slate-500 dark:text-slate-400">
                                            @item.ScheduleDate.ToString("dddd")
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <span class="inline-flex items-center px-5 py-2 bg-emerald-100 dark:bg-emerald-900/70 text-emerald-700 dark:text-emerald-300 rounded-2xl text-sm font-medium">
                                            @item.AvailableTime
                                        </span>
                                    </td>
                                    <td class="px-8 py-6 text-center">
                                        <span class="inline-block px-6 py-2 bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 text-xs font-semibold rounded-2xl">
                                            Confirmed
                                        </span>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="flex justify-center gap-3">
                                            <a asp-action="CreateOrEdit" asp-route-id="@item.Id"
                                               class="p-3 hover:bg-amber-100 dark:hover:bg-amber-900 text-amber-600 dark:text-amber-400 rounded-2xl transition-all hover:scale-110">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Details" asp-route-id="@item.Id"
                                               class="p-3 hover:bg-sky-100 dark:hover:bg-sky-900 text-sky-600 dark:text-sky-400 rounded-2xl transition-all hover:scale-110">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id"
                                               class="p-3 hover:bg-red-100 dark:hover:bg-red-900 text-red-600 dark:text-red-400 rounded-2xl transition-all hover:scale-110"
                                               onclick="return confirm('Are you sure you want to delete this schedule?')">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                serial++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-24">
                                    <div class="flex flex-col items-center justify-center">
                                        <i class="fas fa-calendar-times text-7xl text-slate-300 dark:text-slate-600 mb-6"></i>
                                        <p class="text-2xl font-medium text-slate-500 dark:text-slate-400">No schedules found</p>
                                        <p class="text-slate-400 mt-3 max-w-xs">Get started by adding your first advocate schedule</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@model AMS.Models.AdvocateSchedule

@{
    ViewData["Title"] = Model.Id == 0 ? "Create Schedule" : "Edit Schedule";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-300 p-6 lg:p-8">
    <div class="max-w-2xl mx-auto">

        <!-- Header -->
        <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 bg-emerald-600 rounded-2xl flex items-center justify-center text-3xl text-white">
                📅
            </div>
            <div>
                <h1 class="text-4xl font-bold text-slate-900 dark:text-white">
                    @(Model.Id == 0 ? "Create New Schedule" : "Edit Schedule")
                </h1>
                <p class="text-slate-500 dark:text-slate-400">
                    @(Model.Id == 0 ? "Add availability for Advocate" : "Update schedule details")
                </p>
            </div>
        </div>

        <!-- Form Card -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-3xl p-8 lg:p-10 shadow-sm">
            <form asp-action="CreateOrEdit" method="post" class="space-y-8">
                <input type="hidden" asp-for="Id" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    <!-- Schedule Date -->
                    <div>
                        <label class="block text-sm font-medium text-slate-500 dark:text-slate-400 mb-2">
                            Schedule Date
                        </label>
                        <input type="date" asp-for="ScheduleDate"
                               class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl px-5 py-4 text-slate-900 dark:text-white focus:border-emerald-500 focus:outline-none transition" />
                    </div>

                    <!-- Available Time -->
                    <div>
                        <label class="block text-sm font-medium text-slate-500 dark:text-slate-400 mb-2">
                            Available Time
                        </label>
                        <input type="text" asp-for="AvailableTime" placeholder="e.g. 10:00 AM - 11:30 AM"
                               class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl px-5 py-4 text-slate-900 dark:text-white focus:border-emerald-500 focus:outline-none transition" />
                    </div>

                </div>

                <!-- Advocate Dropdown -->
                <div>
                    <label class="block text-sm font-medium text-slate-500 dark:text-slate-400 mb-2">
                        Advocate
                    </label>
                    <select asp-for="AdvocateId"
                            class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl px-5 py-4 text-slate-900 dark:text-white focus:border-emerald-500 focus:outline-none transition">
                        <option value="">-- Select Advocate --</option>
                        <!-- Populate advocates from controller using ViewBag or SelectList -->
                    </select>
                </div>

                <div class="flex gap-4 pt-8 border-t border-slate-200 dark:border-slate-700">
                    <button type="submit"
                            class="flex-1 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white py-4 rounded-3xl font-semibold text-lg transition-all duration-200">
                        @(Model.Id == 0 ? "Create Schedule" : "Update Schedule")
                    </button>

                    <a asp-action="Index"
                       class="flex-1 border border-slate-300 dark:border-slate-600 hover:bg-slate-100 dark:hover:bg-slate-800 py-4 rounded-3xl font-semibold text-center transition">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
@{
    ViewData["Title"] = "Schedule Details";
}

<div class="min-h-screen bg-slate-950 text-white p-6 lg:p-8">
    <div class="max-w-3xl mx-auto">

        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-emerald-600 rounded-2xl flex items-center justify-center text-3xl">📅</div>
                <div>
                    <h1 class="text-4xl font-bold">Schedule Details</h1>
                    <p class="text-slate-400">Advocate Schedule Information</p>
                </div>
            </div>

            <div class="flex gap-3">
                <a asp-action="Edit" asp-route-id="@Model.Id"
                   class="px-6 py-3 bg-amber-600 hover:bg-amber-500 rounded-2xl font-medium flex items-center gap-2 transition">
                    <i class="fas fa-edit"></i> Edit
                </a>
                <a asp-action="Index"
                   class="px-6 py-3 border border-slate-600 hover:bg-slate-800 rounded-2xl font-medium transition">
                    Back to List
                </a>
            </div>
        </div>

        <!-- Main Content Card -->
        <div class="bg-slate-900 border border-slate-700 rounded-3xl p-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

                <!-- Schedule Information -->
                <div class="space-y-8">
                    <div>
                        <p class="text-slate-400 text-sm mb-1">Schedule Date</p>
                        <p class="text-3xl font-semibold">@Model.ScheduleDate.ToString("dd MMMM yyyy")</p>
                    </div>

                    <div>
                        <p class="text-slate-400 text-sm mb-1">Available Time</p>
                        <p class="text-3xl font-semibold text-emerald-400">@Model.AvailableTime</p>
                    </div>

                    <div>
                        <p class="text-slate-400 text-sm mb-1">Status</p>
                        <span class="inline-flex items-center gap-2 px-5 py-2 bg-emerald-500/10 text-emerald-400 rounded-2xl text-sm font-medium">
                            <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
                            Confirmed
                        </span>
                    </div>
                </div>

                <!-- Advocate Information -->
                <div class="space-y-8">
                    <div>
                        <p class="text-slate-400 text-sm mb-1">Advocate</p>
                        <div class="flex items-center gap-4">
                            <div class="w-14 h-14 bg-slate-700 rounded-2xl flex items-center justify-center text-2xl">⚖️</div>
                            <div>
                                <p class="text-xl font-semibold">@Model.Advocate?.FullName</p>
                                <p class="text-slate-400">@Model.Advocate?.Designation</p>
                            </div>
                        </div>
                    </div>

                    <div>
                        <p class="text-slate-400 text-sm mb-1">Schedule ID</p>
                        <p class="font-mono text-slate-300">#SCH-@Model.Id</p>
                    </div>

                    <div>
                        <p class="text-slate-400 text-sm mb-1">Created On</p>
                        <p class="text-slate-300">@Model.CreatedDate?.ToString("dd MMM yyyy hh:mm tt")</p>
                    </div>
                </div>
            </div>

            <!-- Additional Actions -->
            <div class="mt-12 pt-8 border-t border-slate-700 flex flex-wrap gap-4">
                <button onclick="confirmDelete(@Model.Id)"
                        class="px-6 py-3 text-rose-400 hover:bg-rose-500/10 rounded-2xl font-medium transition flex items-center gap-2">
                    <i class="fas fa-trash"></i> Delete Schedule
                </button>

                <a href="#"
                   class="px-6 py-3 text-emerald-400 hover:bg-emerald-500/10 rounded-2xl font-medium transition flex items-center gap-2">
                    <i class="fas fa-calendar-plus"></i> Add to Google Calendar
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    function confirmDelete(id) {
        if (confirm("Are you sure you want to delete this schedule?")) {
            window.location.href = `/AdvocateSchedule/Delete/${id}`;
        }
    }
</script>
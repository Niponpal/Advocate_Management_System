@model AMS.Models.Appointment

@{
    ViewData["Title"] = Model.Id == 0 ? "New Appointment" : "Edit Appointment";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-300 p-6 lg:p-8">
    <div class="max-w-2xl mx-auto">

        <!-- Header -->
        <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 bg-emerald-600 rounded-2xl flex items-center justify-center text-3xl text-white">
                ⚖️
            </div>
            <div>
                <h1 class="text-4xl font-bold text-slate-900 dark:text-white">
                    @(Model.Id == 0 ? "Create New Appointment" : "Edit Appointment")
                </h1>
                <p class="text-slate-500 dark:text-slate-400">
                    @(Model.Id == 0 ? "Schedule a new client meeting or court date" : $"#AP-{Model.Id}")
                </p>
            </div>
        </div>

        <!-- Form Card -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-3xl p-8 lg:p-10 shadow-sm">

            <form asp-action="CreateOrEdit" method="post" class="space-y-8">
                <input type="hidden" asp-for="Id" />

                <div class="grid grid-cols-1 gap-8">

                    <!-- Appointment Date & Time -->
                    <div>
                        <label class="block text-sm font-medium text-slate-500 dark:text-slate-400 mb-2">
                            Appointment Date & Time <span class="text-rose-500">*</span>
                        </label>
                        <input type="datetime-local" asp-for="AppointmentDate"
                               class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl px-5 py-4 text-slate-900 dark:text-white focus:border-emerald-500 focus:outline-none transition" />
                        <span asp-validation-for="AppointmentDate" class="text-rose-500 text-sm mt-1"></span>
                    </div>

                    <!-- Client Dropdown -->
                    <div>
                        <label class="block text-sm font-medium text-slate-500 dark:text-slate-400 mb-2">
                            Client <span class="text-rose-500">*</span>
                        </label>
                        <select asp-for="ClientId"
                                class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl px-5 py-4 text-slate-900 dark:text-white focus:border-emerald-500 focus:outline-none transition">
                            <option value="">-- Select Client --</option>
                            <!-- Will be populated from ViewBag in Controller -->
                        </select>
                        <span asp-validation-for="ClientId" class="text-rose-500 text-sm mt-1"></span>
                    </div>

                    <!-- Advocate Dropdown -->
                    <div>
                        <label class="block text-sm font-medium text-slate-500 dark:text-slate-400 mb-2">
                            Advocate <span class="text-rose-500">*</span>
                        </label>
                        <select asp-for="AdvocateId"
                                class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl px-5 py-4 text-slate-900 dark:text-white focus:border-emerald-500 focus:outline-none transition">
                            <option value="">-- Select Advocate --</option>
                            <!-- Will be populated from ViewBag in Controller -->
                        </select>
                        <span asp-validation-for="AdvocateId" class="text-rose-500 text-sm mt-1"></span>
                    </div>

                    <!-- Purpose -->
                    <div>
                        <label class="block text-sm font-medium text-slate-500 dark:text-slate-400 mb-2">
                            Purpose <span class="text-rose-500">*</span>
                        </label>
                        <textarea asp-for="Purpose" rows="4"
                                  class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl px-5 py-4 text-slate-900 dark:text-white focus:border-emerald-500 focus:outline-none resize-y transition"
                                  placeholder="Enter appointment purpose (e.g., Client meeting, Document review, Court hearing...)"></textarea>
                        <span asp-validation-for="Purpose" class="text-rose-500 text-sm mt-1"></span>
                    </div>

                    <!-- Status -->
                    <div>
                        <label class="block text-sm font-medium text-slate-500 dark:text-slate-400 mb-2">
                            Status
                        </label>
                        <select asp-for="Status"
                                class="w-full bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl px-5 py-4 text-slate-900 dark:text-white focus:border-emerald-500 focus:outline-none transition">
                            <option value="Scheduled">Scheduled</option>
                            <option value="Rescheduled">Rescheduled</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                    </div>

                </div>

                <!-- Action Buttons -->
                <div class="flex gap-4 pt-8 border-t border-slate-200 dark:border-slate-700">
                    <button type="submit"
                            class="flex-1 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white py-4 rounded-3xl font-semibold text-lg transition-all duration-200">
                        @(Model.Id == 0 ? "Create Appointment" : "Update Appointment")
                    </button>
                    <a asp-action="Index"
                       class="flex-1 border border-slate-300 dark:border-slate-600 hover:bg-slate-100 dark:hover:bg-slate-800 py-4 rounded-3xl font-semibold text-center transition">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
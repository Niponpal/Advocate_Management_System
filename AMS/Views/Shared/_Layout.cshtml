<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AdvocatePro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />

    <script>
        // Tailwind Script for Dark Mode
        tailwind.config = {
            content: [],
            darkMode: 'class', // Important for dark mode
            theme: {
                extend: {}
            }
        }
    </script>

    <style>
        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        .card-hover {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

            .card-hover:hover {
                transform: translateY(-6px);
                box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
            }

        .logo-gradient {
            background: linear-gradient(135deg, #1e3a8a, #312e81);
        }

        .dark .logo-gradient {
            background: linear-gradient(135deg, #3b82f6, #6366f1);
        }
    </style>
</head>
<body class="bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-300 min-h-screen">

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <div class="w-72 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 flex flex-col">
            <!-- Logo -->
            <div class="p-6 border-b border-slate-200 dark:border-slate-800 flex items-center gap-3">
                <div class="w-10 h-10 logo-gradient rounded-2xl flex items-center justify-center text-white font-bold text-2xl shadow-inner">
                    AP
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-800 dark:text-white tracking-tight">AdvocatePro</h1>
                    <p class="text-xs text-slate-500 dark:text-slate-400">Law Firm Management</p>
                </div>
            </div>

            <nav class="flex-1 p-4 overflow-y-auto">
                <ul class="space-y-1">
                    <li>
                        <a href="#" class="flex items-center gap-3 px-4 py-3 bg-indigo-50 dark:bg-indigo-950 text-indigo-700 dark:text-indigo-400 rounded-2xl font-medium">
                            <i class="fas fa-home"></i> Dashboard
                        </a>
                    </li>
                    <li>
                        <a href="#" class="flex items-center gap-3 px-4 py-3 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-2xl transition-colors">
                            <i class="fas fa-user-tie"></i> Advocates
                        </a>
                    </li>
                    <li>
                        <a href="#" class="flex items-center gap-3 px-4 py-3 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-2xl transition-colors">
                            <i class="fas fa-briefcase"></i> Cases
                        </a>
                    </li>
                    <li>
                        <a href="#" class="flex items-center gap-3 px-4 py-3 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-2xl transition-colors">
                            <i class="fas fa-users"></i> Clients
                        </a>
                    </li>
                </ul>
            </nav>

            <!-- User Section -->
            <div class="p-4 border-t border-slate-200 dark:border-slate-800">
                <div class="flex items-center gap-3 p-3 bg-slate-50 dark:bg-slate-800 rounded-2xl">
                    <img src="https://i.pravatar.cc/48?u=adv" class="w-10 h-10 rounded-full ring-2 ring-slate-200 dark:ring-slate-700">
                    <div>
                        <p class="font-semibold text-slate-800 dark:text-white">Adv. Rahim Khan</p>
                        <p class="text-sm text-slate-500 dark:text-slate-400">Senior Advocate</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Top Navbar -->
            <header class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 px-8 py-5 flex items-center justify-between">
                <h2 class="text-3xl font-bold text-slate-800 dark:text-white tracking-tight">@ViewData["Title"]</h2>

                <div class="flex items-center gap-6">
                    <div class="relative">
                        <input type="text" id="search"
                               class="w-80 bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 focus:border-indigo-500 rounded-2xl py-3 px-5 text-sm focus:outline-none transition"
                               placeholder="Search cases, advocates, clients...">
                    </div>

                    <button onclick="toggleTheme()"
                            class="p-3 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-2xl transition">
                        <i class="fas fa-moon text-xl" id="theme-icon"></i>
                    </button>

                    <button class="relative p-3 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-2xl transition">
                        <i class="fas fa-bell text-xl"></i>
                        <span class="absolute top-2 right-2 w-5 h-5 bg-rose-500 text-white text-xs rounded-full flex items-center justify-center">7</span>
                    </button>

                    <div class="flex items-center gap-3">
                        <div class="text-right">
                            <p class="font-medium text-slate-800 dark:text-white">Rahim Khan</p>
                            <p class="text-xs text-emerald-600">Online</p>
                        </div>
                        <img src="https://i.pravatar.cc/48?u=rahim" class="w-10 h-10 rounded-2xl border-2 border-white dark:border-slate-700 shadow">
                    </div>
                </div>
            </header>

            <!-- Page Content -->
            <div class="flex-1 overflow-auto p-8">
                @RenderBody()
            </div>
            @RenderSection("Scripts", required: false)
        </div>
    </div>

    <script>
        function initTheme() {
            const html = document.documentElement;
            const icon = document.getElementById('theme-icon');

            if (localStorage.theme === 'dark' ||
                (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                html.classList.add('dark');
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
            } else {
                html.classList.remove('dark');
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
            }
        }

        function toggleTheme() {
            const html = document.documentElement;
            const icon = document.getElementById('theme-icon');

            if (html.classList.contains('dark')) {
                html.classList.remove('dark');
                localStorage.theme = 'light';
                icon.classList.remove('fa-moon');
                icon.classList.add('fa-sun');
            } else {
                html.classList.add('dark');
                localStorage.theme = 'dark';
                icon.classList.remove('fa-sun');
                icon.classList.add('fa-moon');
            }
        }

        // Initialize theme when page loads
        window.onload = initTheme;
    </script>
</body>
</html>
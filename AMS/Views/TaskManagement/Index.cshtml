@model IEnumerable<AMS.Models.TaskManagement>

@{
    ViewData["Title"] = "Tasks";
}

<div class="min-h-screen bg-slate-950 text-white p-8">
    <div class="max-w-7xl mx-auto space-y-10">

        <!-- Header -->
        <div class="flex justify-between items-end">
            <div>
                <h1 class="text-4xl font-bold">Task Management</h1>
                <p class="text-slate-400 mt-2">Manage all assigned tasks efficiently</p>
            </div>
            <button onclick="newTask()"
                    class="px-8 py-4 bg-emerald-600 hover:bg-emerald-500 transition-all rounded-2xl font-semibold flex items-center gap-3 text-lg shadow-lg shadow-emerald-500/30">
                <i class="fas fa-plus"></i>
                New Task
            </button>
        </div>

        <!-- Filters -->
        <div class="bg-slate-900 border border-slate-800 rounded-3xl p-6 flex flex-wrap gap-4 items-center">
            <div class="flex-1 min-w-[300px]">
                <input type="text" id="searchInput"
                       class="w-full bg-slate-800 border border-slate-700 focus:border-emerald-500 rounded-2xl py-4 px-6 text-sm focus:outline-none"
                       placeholder="Search tasks...">
            </div>

            <select id="statusFilter"
                    class="bg-slate-800 border border-slate-700 rounded-2xl py-4 px-6 focus:outline-none focus:border-emerald-500">
                <option value="">All Status</option>
                <option value="Pending">Pending</option>
                <option value="In Progress">In Progress</option>
                <option value="Completed">Completed</option>
                <option value="Overdue">Overdue</option>
            </select>

            <button onclick="filterTasks()"
                    class="px-8 py-4 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-2xl font-medium transition">
                <i class="fas fa-filter"></i> Filter
            </button>
        </div>

        <!-- Tasks Table -->
        <div class="bg-slate-900 border border-slate-800 rounded-3xl overflow-hidden">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-slate-700 text-slate-400 text-sm">
                        <th class="text-left py-6 px-8 font-medium">Task Title</th>
                        <th class="text-left py-6 px-8 font-medium">Advocate</th>
                        <th class="text-left py-6 px-8 font-medium">Description</th>
                        <th class="text-left py-6 px-8 font-medium">Due Date</th>
                        <th class="text-left py-6 px-8 font-medium">Status</th>
                        <th class="w-24"></th>
                    </tr>
                </thead>
                <tbody id="taskTableBody" class="divide-y divide-slate-800 text-slate-300">
                    <!-- Populated by JavaScript or Razor -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- New Task Modal -->
<div id="newTaskModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center z-50">
    <div class="bg-slate-900 border border-slate-700 rounded-3xl w-full max-w-lg mx-4">
        <div class="p-8">
            <h2 class="text-2xl font-semibold mb-6">Create New Task</h2>
            <!-- Add your form fields here -->
            <div class="space-y-6">
                <div>
                    <label class="block text-sm text-slate-400 mb-2">Task Title</label>
                    <input type="text" class="w-full bg-slate-800 border border-slate-700 rounded-2xl py-4 px-6 focus:outline-none focus:border-emerald-500">
                </div>
                <div>
                    <label class="block text-sm text-slate-400 mb-2">Description</label>
                    <textarea class="w-full bg-slate-800 border border-slate-700 rounded-2xl py-4 px-6 focus:outline-none focus:border-emerald-500 h-32"></textarea>
                </div>
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm text-slate-400 mb-2">Due Date</label>
                        <input type="date" class="w-full bg-slate-800 border border-slate-700 rounded-2xl py-4 px-6 focus:outline-none focus:border-emerald-500">
                    </div>
                    <div>
                        <label class="block text-sm text-slate-400 mb-2">Advocate</label>
                        <select class="w-full bg-slate-800 border border-slate-700 rounded-2xl py-4 px-6 focus:outline-none focus:border-emerald-500">
                            <option>Adv. Rahim Khan</option>
                            <option>Adv. Fatima Begum</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
        <div class="border-t border-slate-700 p-6 flex gap-4">
            <button onclick="closeModal()"
                    class="flex-1 py-4 border border-slate-700 rounded-2xl hover:bg-slate-800 transition">
                Cancel
            </button>
            <button onclick="saveTask()"
                    class="flex-1 py-4 bg-emerald-600 hover:bg-emerald-500 rounded-2xl font-semibold transition">
                Create Task
            </button>
        </div>
    </div>
</div>

<script>
    // Sample Data (Replace with @Model from controller)
    const tasks = [
        {
            id: 1,
            title: "Prepare witness statements",
            advocate: "Adv. Rahim Khan",
            description: "For State vs Karim Ahmed case",
            dueDate: "2026-06-25",
            status: "In Progress"
        },
        {
            id: 2,
            title: "File appeal documents",
            advocate: "Adv. Fatima Begum",
            description: "Property dispute - Rahman Family",
            dueDate: "2026-06-20",
            status: "Pending"
        },
        {
            id: 3,
            title: "Client meeting preparation",
            advocate: "Adv. Rahim Khan",
            description: "Land acquisition case briefing",
            dueDate: "2026-06-22",
            status: "Overdue"
        }
    ];

    function getStatusBadge(status) {
        let color = '';
        switch(status.toLowerCase()) {
            case 'completed': color = 'emerald'; break;
            case 'in progress': color = 'blue'; break;
            case 'pending': color = 'amber'; break;
            case 'overdue': color = 'rose'; break;
            default: color = 'slate';
        }
        return `<span class="px-5 py-2 bg-${color}-500/20 text-${color}-400 rounded-2xl text-xs font-semibold">${status}</span>`;
    }

    function formatDate(dateStr) {
        const date = new Date(dateStr);
        const today = new Date();
        const diffTime = date - today;
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

        let className = '';
        if (diffDays < 0) className = 'text-rose-400';
        else if (diffDays <= 3) className = 'text-amber-400';

        return `<span class="${className}">${date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>`;
    }

    function renderTasks(filteredTasks) {
        const tbody = document.getElementById('taskTableBody');
        tbody.innerHTML = '';

        filteredTasks.forEach(task => {
            const row = `
                <tr class="hover:bg-slate-800/70 transition group">
                    <td class="py-6 px-8 font-medium">${task.title}</td>
                    <td class="py-6 px-8">${task.advocate}</td>
                    <td class="py-6 px-8 text-slate-400 text-sm">${task.description}</td>
                    <td class="py-6 px-8">${formatDate(task.dueDate)}</td>
                    <td class="py-6 px-8">${getStatusBadge(task.status)}</td>
                    <td class="py-6 px-8 text-right">
                        <button class="text-slate-400 hover:text-emerald-400 transition">
                            <i class="fas fa-edit"></i>
                        </button>
                    </td>
                </tr>`;
            tbody.innerHTML += row;
        });
    }

    // Search & Filter
    function filterTasks() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const statusFilter = document.getElementById('statusFilter').value;

        const filtered = tasks.filter(task => {
            const matchesSearch = task.title.toLowerCase().includes(searchTerm) ||
                                task.description.toLowerCase().includes(searchTerm);
            const matchesStatus = !statusFilter || task.status === statusFilter;
            return matchesSearch && matchesStatus;
        });

        renderTasks(filtered);
    }

    function newTask() {
        document.getElementById('newTaskModal').classList.remove('hidden');
    }

    function closeModal() {
        document.getElementById('newTaskModal').classList.add('hidden');
    }

    function saveTask() {
        alert("✅ Task created successfully!");
        closeModal();
        // In real app: refresh table after API call
    }

    // Initialize
    window.onload = function() {
        initTheme();
        renderTasks(tasks);

        // Live search
        document.getElementById('searchInput').addEventListener('keyup', filterTasks);
    };
</script>
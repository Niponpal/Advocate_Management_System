@model IEnumerable<AMS.Models.TaskManagement>

@{
    ViewData["Title"] = "Tasks";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-300 p-8 transition-colors">
    <div class="max-w-7xl mx-auto space-y-10">

        <!-- Header -->
        <div class="flex justify-between items-end">
            <div>
                <h1 class="text-4xl font-bold text-slate-800 dark:text-white">Task Management</h1>
                <p class="text-slate-500 dark:text-slate-400 mt-2">Manage all assigned tasks efficiently</p>
            </div>
            <button onclick="newTask()"
                    class="px-8 py-4 bg-emerald-600 hover:bg-emerald-500 text-white transition-all rounded-2xl font-semibold flex items-center gap-3 text-lg shadow-lg shadow-emerald-500/30">
                <i class="fas fa-plus"></i>
                New Task
            </button>
        </div>

        <!-- Filters -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 flex flex-wrap gap-4 items-center">
            <div class="flex-1 min-w-[300px]">
                <input type="text" id="searchInput"
                       class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 focus:border-emerald-500 rounded-2xl py-4 px-6 text-sm focus:outline-none transition-colors"
                       placeholder="Search tasks...">
            </div>

            <select id="statusFilter"
                    class="bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl py-4 px-6 focus:outline-none focus:border-emerald-500 transition-colors">
                <option value="">All Status</option>
                <option value="Pending">Pending</option>
                <option value="In Progress">In Progress</option>
                <option value="Completed">Completed</option>
                <option value="Overdue">Overdue</option>
            </select>

            <button onclick="filterTasks()"
                    class="px-8 py-4 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 border border-slate-200 dark:border-slate-700 rounded-2xl font-medium transition">
                <i class="fas fa-filter"></i> Filter
            </button>
        </div>

        <!-- Tasks Table -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl overflow-hidden">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400 text-sm">
                        <th class="text-left py-6 px-8 font-medium">Task Title</th>
                        <th class="text-left py-6 px-8 font-medium">Advocate</th>
                        <th class="text-left py-6 px-8 font-medium">Description</th>
                        <th class="text-left py-6 px-8 font-medium">Due Date</th>
                        <th class="text-left py-6 px-8 font-medium">Status</th>
                        <th class="w-24"></th>
                    </tr>
                </thead>
                <tbody id="taskTableBody" class="divide-y divide-slate-100 dark:divide-slate-800 text-slate-700 dark:text-slate-300">
                    <!-- JS দিয়ে পপুলেট হবে -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- New Task Modal -->
<div id="newTaskModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center z-50">
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-3xl w-full max-w-lg mx-4">
        <!-- Modal content with dark mode support -->
        <div class="p-8">
            <h2 class="text-2xl font-semibold text-slate-800 dark:text-white mb-6">Create New Task</h2>
            <!-- Form fields with proper dark classes -->
            <div class="space-y-6">
                <div>
                    <label class="block text-sm text-slate-500 dark:text-slate-400 mb-2">Task Title</label>
                    <input type="text" class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl py-4 px-6 focus:outline-none focus:border-emerald-500">
                </div>
                <!-- Add other fields similarly -->
            </div>
        </div>
        <div class="border-t border-slate-200 dark:border-slate-700 p-6 flex gap-4">
            <button onclick="closeModal()"
                    class="flex-1 py-4 border border-slate-300 dark:border-slate-700 rounded-2xl hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-300 transition">
                Cancel
            </button>
            <button onclick="saveTask()"
                    class="flex-1 py-4 bg-emerald-600 hover:bg-emerald-500 text-white rounded-2xl font-semibold transition">
                Create Task
            </button>
        </div>
    </div>
</div>

<script>
    // ... (আগের JS কোড একই রাখুন - শুধু renderTasks ফাংশনে status badge আপডেট করুন)

    function getStatusBadge(status) {
        let color = '';
        switch(status.toLowerCase()) {
            case 'completed': color = 'emerald'; break;
            case 'in progress': color = 'blue'; break;
            case 'pending': color = 'amber'; break;
            case 'overdue': color = 'rose'; break;
            default: color = 'slate';
        }
        return `<span class="px-5 py-2 bg-${color}-500/10 dark:bg-${color}-500/20 text-${color}-600 dark:text-${color}-400 rounded-2xl text-xs font-semibold">${status}</span>`;
    }

    // Initialize
    window.onload = function() {
        initTheme();           // এটা খুব জরুরি
        renderTasks(tasks);
        document.getElementById('searchInput').addEventListener('keyup', filterTasks);
    };
</script>
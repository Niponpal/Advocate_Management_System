@model AMS.Models.LegalNotice
@{
    ViewData["Title"] = Model?.Id == 0 ? "Create Legal Notice" : "Edit Legal Notice";
}

<div class="flex-1 overflow-auto p-8 bg-slate-50 dark:bg-slate-950 transition-colors">
    <div class="max-w-4xl mx-auto">
        <!-- Page Header -->
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-4xl font-bold text-slate-800 dark:text-white tracking-tight">
                    @if (Model?.Id == 0)
                    {
                        <text>Create Legal Notice</text>
                    }
                    else
                    {

                        <text>Edit Legal Notice</text>
                    }
                </h1>
                <p class="text-slate-500 dark:text-slate-400 mt-2">Add a new legal notice for a client</p>
            </div>
            <a asp-action="Index"
               class="px-6 py-3 bg-slate-200 dark:bg-slate-800 hover:bg-slate-300 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-2xl font-medium flex items-center gap-2 transition">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>

        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl shadow-xl">
            <div class="p-8 border-b border-slate-200 dark:border-slate-700">
                <h3 class="text-2xl font-semibold text-slate-800 dark:text-white">
                    @if (Model?.Id == 0)
                    {
                        <text>New Legal Notice Details</text>
                    }
                    else
                    {

                        <text>Edit Legal Notice Details</text>
                    }
                </h3>
            </div>
            <div class="p-8">
                <form method="post" class="space-y-8" asp-action="CreateOrEdit">
                    <div asp-validation-summary="ModelOnly" class="text-red-500"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Notice Title -->
                        <div class="md:col-span-2">
                            <label asp-for="NoticeTitle" class="block text-sm font-medium text-slate-600 dark:text-slate-400 mb-2"></label>
                            <input asp-for="NoticeTitle"
                                   class="w-full px-6 py-4 bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 focus:border-emerald-500 rounded-2xl focus:outline-none transition text-slate-800 dark:text-white"
                                   placeholder="Enter notice title" required />
                            <span asp-validation-for="NoticeTitle" class="text-red-500 text-sm mt-1"></span>
                        </div>

                        <!-- Notice Date -->
                        <div>
                            <label asp-for="NoticeDate" class="block text-sm font-medium text-slate-600 dark:text-slate-400 mb-2"></label>
                            <input asp-for="NoticeDate" type="date"
                                   class="w-full px-6 py-4 bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 focus:border-emerald-500 rounded-2xl focus:outline-none transition text-slate-800 dark:text-white" required />
                            <span asp-validation-for="NoticeDate" class="text-red-500 text-sm mt-1"></span>
                        </div>

                        <!-- Client -->
                        <div>
                            <label asp-for="ClientId" class="block text-sm font-medium text-slate-600 dark:text-slate-400 mb-2"></label>
                            <select asp-for="ClientId" asp-items="ViewBag.Clients"
                                    class="w-full px-6 py-4 bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 focus:border-emerald-500 rounded-2xl focus:outline-none transition text-slate-800 dark:text-white" required>
                                <option value="">-- Select Client --</option>
                            </select>
                            <span asp-validation-for="ClientId" class="text-red-500 text-sm mt-1"></span>
                        </div>

                        <!-- Description -->
                        <div class="md:col-span-2">
                            <label asp-for="Description" class="block text-sm font-medium text-slate-600 dark:text-slate-400 mb-2"></label>
                            <textarea asp-for="Description" rows="6"
                                      class="w-full px-6 py-4 bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 focus:border-emerald-500 rounded-3xl focus:outline-none transition text-slate-800 dark:text-white resize-y"
                                      placeholder="Enter detailed description of the legal notice..."></textarea>
                            <span asp-validation-for="Description" class="text-red-500 text-sm mt-1"></span>
                        </div>
                    </div>

                    <div class="flex gap-4 pt-6 border-t border-slate-200 dark:border-slate-700">
                        <button type="submit"
                                class="px-10 py-4 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold rounded-2xl flex items-center gap-3 text-lg shadow-lg shadow-emerald-500/30 transition">
                            <i class="fas fa-save"></i>
                            @(Model?.Id == 0 ? "Create Notice" : "Update Notice")
                        </button>
                        <a asp-action="Index"
                           class="px-10 py-4 bg-slate-200 dark:bg-slate-800 hover:bg-slate-300 dark:hover:bg-slate-700 font-semibold rounded-2xl flex items-center gap-3 text-lg transition">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
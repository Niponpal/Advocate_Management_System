@model IEnumerable<AMS.Models.LegalNotice>

@{
    ViewData["Title"] = "Legal Notices";
}

<div class="flex-1 overflow-auto p-8 bg-slate-950">
    <div class="max-w-7xl mx-auto space-y-10">

        <!-- Page Header -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6">
            <div>
                <h1 class="text-4xl font-bold text-white tracking-tight">Legal Notices</h1>
                <p class="text-slate-400 mt-2">Manage all legal notices issued to clients</p>
            </div>

            <a asp-action="Create"
               class="px-8 py-4 bg-emerald-600 hover:bg-emerald-500 transition-all rounded-2xl font-semibold flex items-center gap-3 text-lg shadow-lg shadow-emerald-500/30">
                <i class="fas fa-plus"></i>
                New Legal Notice
            </a>
        </div>

        <!-- Stats Bar -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-slate-900 border border-slate-800 rounded-3xl p-8 hover:border-emerald-500/50 transition-all">
                <p class="text-slate-400 text-sm">Total Notices</p>
                <p class="text-5xl font-bold text-white mt-4">@(Model?.Count() ?? 0)</p>
            </div>
            <div class="bg-slate-900 border border-slate-800 rounded-3xl p-8 hover:border-emerald-500/50 transition-all">
                <p class="text-slate-400 text-sm">This Month</p>
                <p class="text-5xl font-bold text-emerald-400 mt-4">
                    @(Model?.Count(m => m.NoticeDate.Month == DateTime.Now.Month && m.NoticeDate.Year == DateTime.Now.Year) ?? 0)
                </p>
            </div>
            <div class="bg-slate-900 border border-slate-800 rounded-3xl p-8 hover:border-amber-500/50 transition-all">
                <p class="text-slate-400 text-sm">Pending Response</p>
                <p class="text-5xl font-bold text-amber-400 mt-4">7</p>
            </div>
        </div>

        <!-- Search & Filter -->
        <div class="bg-slate-900 border border-slate-800 rounded-3xl p-6 flex flex-col md:flex-row gap-4">
            <div class="flex-1 relative">
                <input type="text" id="searchInput"
                       class="w-full bg-slate-800 border border-slate-700 focus:border-emerald-500 rounded-2xl py-4 px-6 text-white placeholder-slate-500 focus:outline-none transition"
                       placeholder="Search by notice title or client name...">
            </div>
            <button onclick="filterTable()"
                    class="px-10 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-2xl flex items-center gap-3 font-medium">
                <i class="fas fa-filter"></i>
                Filter
            </button>
        </div>

        <!-- Legal Notices Table -->
        <div class="bg-slate-900 border border-slate-800 rounded-3xl overflow-hidden">
            <div class="p-8 border-b border-slate-700 flex justify-between items-center">
                <h3 class="text-2xl font-semibold tracking-tight">All Legal Notices</h3>
                <p class="text-slate-400 text-sm">@(Model?.Count() ?? 0) Total</p>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="text-slate-400 text-sm border-b border-slate-700">
                            <th class="px-8 py-6 text-left font-medium">Notice ID</th>
                            <th class="px-8 py-6 text-left font-medium">Title</th>
                            <th class="px-8 py-6 text-left font-medium">Client</th>
                            <th class="px-8 py-6 text-left font-medium">Notice Date</th>
                            <th class="px-8 py-6 text-left font-medium">Status</th>
                            <th class="px-8 py-6 text-right font-medium">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800 text-slate-300" id="noticeTable">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr class="hover:bg-slate-800/70 transition-colors">
                                    <td class="px-8 py-6 font-mono text-emerald-400">#LN-@item.Id</td>
                                    <td class="px-8 py-6 font-medium">@item.NoticeTitle</td>
                                    <td class="px-8 py-6">@(item.Client?.ClientName ?? "N/A")</td>
                                    <td class="px-8 py-6">@item.NoticeDate.ToString("dd MMM yyyy")</td>
                                    <td class="px-8 py-6">
                                        <span class="px-5 py-2 text-xs font-semibold rounded-2xl
                                                    @(DateTime.Now > item.NoticeDate.AddDays(30) ? "bg-rose-500/20 text-rose-400" : "bg-emerald-500/20 text-emerald-400")">
                                            @(DateTime.Now > item.NoticeDate.AddDays(30) ? "Overdue" : "Active")
                                        </span>
                                    </td>
                                    <td class="px-8 py-6 text-right">
                                        <div class="flex justify-end gap-3">
                                            <a asp-action="Details" asp-route-id="@item.Id"
                                               class="px-5 py-2.5 bg-slate-800 hover:bg-slate-700 rounded-2xl text-sm transition">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id"
                                               class="px-5 py-2.5 bg-slate-800 hover:bg-slate-700 rounded-2xl text-sm transition">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <button onclick="deleteNotice(@item.Id)"
                                                    class="px-5 py-2.5 bg-slate-800 hover:bg-rose-500/20 hover:text-rose-400 rounded-2xl text-sm transition">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="px-8 py-20 text-center text-slate-400">
                                    <i class="fas fa-folder-open text-5xl mb-4 opacity-50"></i>
                                    <p class="text-lg">No legal notices found</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="p-6 border-t border-slate-700 flex items-center justify-between text-sm">
                <p class="text-slate-400">Showing @(Model?.Count() ?? 0) notices</p>
                <div class="flex gap-2">
                    <button class="px-5 py-2 bg-slate-800 hover:bg-slate-700 rounded-2xl transition">Previous</button>
                    <button class="px-5 py-2 bg-emerald-600 rounded-2xl">1</button>
                    <button class="px-5 py-2 bg-slate-800 hover:bg-slate-700 rounded-2xl transition">Next</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function filterTable() {
        const input = document.getElementById('searchInput').value.toLowerCase().trim();
        const rows = document.querySelectorAll('#noticeTable tr');

        rows.forEach(row => {
            if (row.cells.length < 2) return;
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(input) ? '' : 'none';
        });
    }

    function deleteNotice(id) {
        if (confirm('Are you sure you want to delete this legal notice?')) {
            window.location.href = `/LegalNotices/Delete/${id}`;
        }
    }
</script>
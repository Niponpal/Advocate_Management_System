@model IEnumerable<AMS.Models.Advocate>
@{
    ViewData["Title"] = "Advocates Directory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold text-slate-800 dark:text-white tracking-tight">
                Advocates Directory
            </h1>
            <p class="text-slate-500 dark:text-slate-400 mt-1">
                Manage and view all registered advocates
            </p>
        </div>
        <a asp-action="CreateOrEdit"
           class="flex items-center gap-3 bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3.5 rounded-2xl font-medium transition-all active:scale-95 shadow-lg shadow-indigo-500/30">
            <i class="fas fa-user-plus"></i>
            Add New Advocate
        </a>
    </div>

    <!-- Main Card -->
    <div class="bg-white dark:bg-slate-900 rounded-3xl shadow border border-slate-200 dark:border-slate-800 overflow-hidden">
        <!-- Card Header -->
        <div class="px-8 py-6 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between bg-slate-50 dark:bg-slate-800">
            <h5 class="text-xl font-semibold text-slate-800 dark:text-white">All Advocates</h5>

            <!-- Custom Search Box -->
            <div class="relative w-80">
                <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                    <i class="fas fa-search"></i>
                </div>
                <input type="text" id="customSearch"
                       class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 focus:border-indigo-500 rounded-2xl py-3 pl-11 pr-5 text-sm focus:outline-none transition-colors"
                       placeholder="Search by name, license or specialization...">
            </div>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
            <table class="w-full" id="advocatesTable">
                <thead class="bg-slate-50 dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700">
                    <tr>
                        <th class="px-8 py-5 text-left text-sm font-medium text-slate-500 dark:text-slate-400">Advocate Name</th>
                        <th class="px-6 py-5 text-left text-sm font-medium text-slate-500 dark:text-slate-400">License No.</th>
                        <th class="px-6 py-5 text-left text-sm font-medium text-slate-500 dark:text-slate-400">Specialization</th>
                        <th class="px-6 py-5 text-left text-sm font-medium text-slate-500 dark:text-slate-400">Contact</th>
                        <th class="px-6 py-5 text-left text-sm font-medium text-slate-500 dark:text-slate-400">Experience</th>
                        <th class="px-8 py-5 text-center text-sm font-medium text-slate-500 dark:text-slate-400">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/70 transition-colors">
                            <td class="px-8 py-6">
                                <div class="flex items-center gap-4">
                                    <div class="w-11 h-11 bg-gradient-to-br from-indigo-500 to-blue-600 text-white rounded-2xl flex items-center justify-center font-bold text-xl shadow-inner">
                                        @item.AdvocateName.Substring(0, 1)
                                    </div>
                                    <div>
                                        <strong class="text-slate-800 dark:text-white text-lg">@item.AdvocateName</strong>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-6">
                                <span class="font-mono text-slate-600 dark:text-slate-400">@item.LicenseNumber</span>
                            </td>
                            <td class="px-6 py-6">
                                @if (!string.IsNullOrEmpty(item.Specialization))
                                {
                                    <span class="inline-block bg-indigo-100 dark:bg-indigo-950 text-indigo-700 dark:text-indigo-400 text-sm px-4 py-2 rounded-2xl font-medium">
                                        @item.Specialization
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-6">
                                <div class="flex items-center gap-2 text-slate-700 dark:text-slate-300">
                                    <i class="fas fa-envelope text-slate-400"></i>
                                    @item.Email
                                </div>
                                <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mt-1">
                                    <i class="fas fa-phone"></i>
                                    @item.Phone
                                </div>
                            </td>
                            <td class="px-6 py-6">
                                <span class="font-semibold text-slate-800 dark:text-white">@item.ExperienceYears</span>
                                <span class="text-slate-500 dark:text-slate-400 text-sm ml-1">years</span>
                            </td>
                            <td class="px-8 py-6 text-center">
                                <div class="inline-flex gap-1 bg-slate-100 dark:bg-slate-800 rounded-2xl p-1">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="p-3 hover:bg-white dark:hover:bg-slate-700 rounded-xl text-slate-500 hover:text-indigo-600 transition">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="CreateOrEdit" asp-route-id="@item.Id" class="p-3 hover:bg-white dark:hover:bg-slate-700 rounded-xl text-slate-500 hover:text-amber-600 transition">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="p-3 hover:bg-white dark:hover:bg-slate-700 rounded-xl text-slate-500 hover:text-red-600 transition"
                                       onclick="return confirm('Are you sure you want to delete this advocate? This action cannot be undone.')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var table = $('#advocatesTable').DataTable({
                "order": [[0, "asc"]],
                "pageLength": 15,
                "lengthMenu": [10, 15, 25, 50],
                "responsive": true,
                "dom": 'lrtip',
                "language": {
                    "search": "",
                    "searchPlaceholder": "Search advocates...",
                    "lengthMenu": "Show _MENU_ entries",
                    "info": "Showing _START_ to _END_ of _TOTAL_ advocates",
                    "zeroRecords": "No matching record found"
                },
                "columnDefs": [
                    { "orderable": false, "targets": 5 }
                ]
            });

            // Custom Search
            $('#customSearch').on('keyup change', function () {
                table.search($.fn.dataTable.util.escapeRegex(this.value.trim())).draw();
            });
        });
    </script>
}
@model IEnumerable<AMS.Models.Advocate>

@{
    ViewData["Title"] = "Advocates Directory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-dark">Advocates Directory</h1>
            <p class="text-muted mb-0">Manage and view all registered advocates</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-user-plus me-2"></i> Add New Advocate
        </a>
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="card-title mb-0">All Advocates</h5>
                </div>
                <div class="col-auto">
                    <div class="input-group" style="width: 280px;">
                        <span class="input-group-text bg-light border-0">
                            <i class="fas fa-search"></i>
                        </span>
                        <input type="text" id="customSearch" class="form-control border-0 bg-light"
                               placeholder="Search by name, license or specialization...">
                    </div>
                </div>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="advocatesTable">
                    <thead class="table-light">
                        <tr>
                            <th width="25%">Advocate Name</th>
                            <th>License No.</th>
                            <th>Specialization</th>
                            <th>Contact</th>
                            <th>Experience</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3"
                                             style="width: 42px; height: 42px; font-size: 1.1rem;">
                                            @item.AdvocateName.Substring(0, 1)
                                        </div>
                                        <div>
                                            <strong>@item.AdvocateName</strong>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-muted">@item.LicenseNumber</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Specialization))
                                    {
                                        <span class="badge bg-info-subtle text-info fw-normal px-3 py-2">@item.Specialization</span>
                                    }
                                </td>
                                <td>
                                    <div>
                                        <i class="fas fa-envelope text-muted me-1"></i> @item.Email
                                    </div>
                                    <div class="small text-muted">
                                        <i class="fas fa-phone me-1"></i> @item.Phone
                                    </div>
                                </td>
                                <td>
                                    <strong>@item.ExperienceYears</strong> <span class="text-muted">years</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-info" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger"
                                           onclick="return confirm('Are you sure you want to delete this advocate? This action cannot be undone.')"
                                           title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var table = $('#advocatesTable').DataTable({
                "order": [[0, "asc"]],
                "pageLength": 15,
                "lengthMenu": [10, 15, 25, 50],
                "responsive": true,
                "language": {
                    search: "",
                    searchPlaceholder: "Search advocates...",
                    lengthMenu: "Show _MENU_ entries",
                    info: "Showing _START_ to _END_ of _TOTAL_ advocates"
                },
                "columnDefs": [
                    { "orderable": false, "targets": 5 }  // Disable sorting on Actions column
                ]
            });

            // Custom search input
            $('#customSearch').keyup(function(){
                table.search(this.value).draw();
            });
        });
    </script>
}
@model IEnumerable<AMS.Models.Invoice>

@{
    ViewData["Title"] = "Invoices";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-300 p-6 lg:p-8 transition-colors">
    <div class="max-w-7xl mx-auto space-y-8">

        <!-- Header -->
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6">
            <div>
                <h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-white">Invoices</h1>
                <p class="text-slate-500 dark:text-slate-400 mt-1">Manage and track all client invoices</p>
            </div>

            <div class="flex items-center gap-4">
                <button onclick="newInvoice()"
                        class="px-6 py-3 bg-emerald-600 hover:bg-emerald-500 text-white transition-all rounded-2xl font-semibold flex items-center gap-3 shadow-lg shadow-emerald-500/30">
                    <i class="fas fa-plus"></i>
                    New Invoice
                </button>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 hover:border-emerald-500/30 transition-all">
                <p class="text-slate-500 dark:text-slate-400 text-sm">Total Invoices</p>
                <p class="text-4xl font-bold mt-3 text-slate-900 dark:text-white">142</p>
                <p class="text-emerald-600 dark:text-emerald-400 text-sm mt-2">↑ 18 this month</p>
            </div>

            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 hover:border-emerald-500/30 transition-all">
                <p class="text-slate-500 dark:text-slate-400 text-sm">Total Receivable</p>
                <p class="text-4xl font-bold mt-3 text-emerald-600 dark:text-emerald-400">৳ 87.4L</p>
                <p class="text-slate-500 dark:text-slate-400 text-sm mt-2">Pending Amount</p>
            </div>

            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 hover:border-emerald-500/30 transition-all">
                <p class="text-slate-500 dark:text-slate-400 text-sm">Paid This Month</p>
                <p class="text-4xl font-bold mt-3 text-slate-900 dark:text-white">৳ 24.8L</p>
                <p class="text-emerald-600 dark:text-emerald-500 text-sm mt-2">↑ 12%</p>
            </div>
        </div>

        <!-- Filters & Search -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <input type="text" id="searchInput"
                       class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl py-4 px-5 focus:outline-none focus:border-emerald-500 transition text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-slate-500"
                       placeholder="Search by Invoice # or Client name...">
            </div>
            <button onclick="filterInvoices()"
                    class="px-8 py-4 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 border border-slate-300 dark:border-slate-700 rounded-2xl transition text-slate-700 dark:text-slate-300">
                <i class="fas fa-filter"></i>
            </button>
        </div>

        <!-- Invoices Table -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400 text-sm">
                            <th class="text-left py-6 px-8 font-medium">Invoice #</th>
                            <th class="text-left py-6 px-8 font-medium">Client</th>
                            <th class="text-left py-6 px-8 font-medium">Invoice Date</th>
                            <th class="text-right py-6 px-8 font-medium">Amount</th>
                            <th class="text-center py-6 px-8 font-medium">Status</th>
                            <th class="text-center py-6 px-8 font-medium">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-slate-800 text-slate-700 dark:text-slate-300" id="invoiceTable">
                        @foreach (var invoice in Model)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/70 transition-colors">
                                <td class="py-6 px-8 font-mono text-emerald-600 dark:text-emerald-400">#INV-@invoice.InvoiceNumber</td>
                                <td class="py-6 px-8">@invoice.Client?.ClientName</td>
                                <td class="py-6 px-8 text-slate-500 dark:text-slate-400">@invoice.InvoiceDate.ToString("dd MMMM yyyy")</td>
                                <td class="py-6 px-8 text-right font-semibold">৳ @invoice.TotalAmount</td>
                                <td class="py-6 px-8 text-center">
                                    @if (true) // Replace with actual status logic
                                    {
                                        <span class="px-5 py-2 bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 rounded-2xl text-xs font-semibold">Paid</span>
                                    }
                                    else
                                    {
                                        <span class="px-5 py-2 bg-amber-100 dark:bg-amber-500/20 text-amber-700 dark:text-amber-400 rounded-2xl text-xs font-semibold">Pending</span>
                                    }
                                </td>
                                <td class="py-6 px-8 text-center flex justify-center gap-3">
                                    <button class="text-slate-400 hover:text-slate-600 dark:hover:text-white transition">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button class="text-slate-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition">
                                        <i class="fas fa-download"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function newInvoice() {
        alert("🧾 New Invoice form will open here");
        // window.location.href = '/Invoice/Create';
    }

    // Live Search
    document.getElementById('searchInput').addEventListener('keyup', function () {
        let filter = this.value.toLowerCase();
        let rows = document.querySelectorAll('#invoiceTable tr');

        rows.forEach(row => {
            let text = row.textContent.toLowerCase();
            row.style.display = text.includes(filter) ? '' : 'none';
        });
    });
</script>
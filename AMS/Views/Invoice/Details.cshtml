@model AMS.Models.Invoice

@{
    ViewData["Title"] = "Invoice Details";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-300 p-6 lg:p-8 transition-colors">
    <div class="max-w-4xl mx-auto">

        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div class="flex items-center gap-4">
                <a href="/Invoice" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition flex items-center gap-2">
                    <i class="fas fa-arrow-left"></i> Back to Invoices
                </a>
            </div>

            <div class="flex items-center gap-3">
                <a href="/Invoice/Edit/@Model.Id"
                   class="px-6 py-3 bg-emerald-600 hover:bg-emerald-500 text-white rounded-2xl font-semibold flex items-center gap-2 transition shadow-lg shadow-emerald-500/30">
                    <i class="fas fa-edit"></i> Edit Invoice
                </a>
                <button onclick="downloadInvoice()"
                        class="px-6 py-3 border border-slate-300 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-2xl font-medium flex items-center gap-2 transition">
                    <i class="fas fa-download"></i> Download PDF
                </button>
            </div>
        </div>

        <!-- Invoice Card -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl overflow-hidden shadow-sm">

            <!-- Invoice Header -->
            <div class="bg-gradient-to-r from-slate-900 to-slate-800 dark:from-slate-800 dark:to-slate-900 p-10 text-white">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
                    <div>
                        <div class="flex items-center gap-3">
                            <div class="w-12 h-12 bg-emerald-600 rounded-2xl flex items-center justify-center text-3xl">🧾</div>
                            <div>
                                <p class="text-emerald-400 text-sm font-medium tracking-widest">INVOICE</p>
                                <h1 class="text-4xl font-bold">#INV-@Model.InvoiceNumber</h1>
                            </div>
                        </div>
                    </div>

                    <div class="text-right">
                        <p class="text-3xl font-semibold text-emerald-400">৳ @Model.TotalAmount</p>
                        <p class="text-slate-400">@Model.InvoiceDate.ToString("dd MMMM yyyy")</p>
                    </div>
                </div>
            </div>

            <!-- Client & Details -->
            <div class="p-10">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

                    <!-- Client Information -->
                    <div>
                        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Client Information</h3>
                        <div class="bg-slate-50 dark:bg-slate-800 rounded-2xl p-6 space-y-3">
                            @if (Model.Client != null)
                            {
                                <p class="font-medium text-lg">@Model.Client.ClientName</p>
                                <p class="text-slate-500 dark:text-slate-400">@Model.Client.Email</p>
                                <p class="text-slate-500 dark:text-slate-400">@Model.Client.Phone</p>
                                <p class="text-slate-500 dark:text-slate-400">@Model.Client.Address</p>
                            }
                            else
                            {
                                <p class="text-slate-500 dark:text-slate-400">Client information not available</p>
                            }
                        </div>
                    </div>

                    <!-- Invoice Details -->
                    <div>
                        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Invoice Details</h3>
                        <div class="space-y-6">
                            <div class="flex justify-between py-3 border-b border-slate-200 dark:border-slate-700">
                                <span class="text-slate-500 dark:text-slate-400">Invoice Number</span>
                                <span class="font-mono font-medium text-emerald-600 dark:text-emerald-400">#INV-@Model.InvoiceNumber</span>
                            </div>
                            <div class="flex justify-between py-3 border-b border-slate-200 dark:border-slate-700">
                                <span class="text-slate-500 dark:text-slate-400">Invoice Date</span>
                                <span class="font-medium">@Model.InvoiceDate.ToString("dd MMMM yyyy")</span>
                            </div>
                            <div class="flex justify-between py-3 border-b border-slate-200 dark:border-slate-700">
                                <span class="text-slate-500 dark:text-slate-400">Total Amount</span>
                                <span class="font-semibold text-xl">৳ @Model.TotalAmount</span>
                            </div>
                            <div class="flex justify-between py-3">
                                <span class="text-slate-500 dark:text-slate-400">Status</span>
                                <span class="px-6 py-2 bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 rounded-2xl text-sm font-semibold">
                                    Paid
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer Note -->
            <div class="border-t border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 p-8 text-center text-slate-500 dark:text-slate-400 text-sm">
                Thank you for your business. Payment is due within 30 days.
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex justify-center gap-4 mt-8">
            <a href="/Invoice"
               class="px-8 py-4 border border-slate-300 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-2xl font-medium transition">
                Back to List
            </a>
        </div>
    </div>
</div>

<script>
    function downloadInvoice() {
        alert("📄 Invoice PDF download started... (Implementation coming soon)");
        // You can integrate jsPDF or server-side PDF generation here
    }
</script>
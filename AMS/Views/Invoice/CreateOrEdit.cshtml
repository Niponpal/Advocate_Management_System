@model AMS.Models.Invoice

@{
    ViewData["Title"] = Model.Id == 0 ? "Create Invoice" : "Edit Invoice";
    bool isEdit = Model.Id != 0;
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-300 p-6 lg:p-8 transition-colors">
    <div class="max-w-3xl mx-auto">

        <!-- Header -->
        <div class="flex items-center gap-4 mb-8">
            <a href="/Invoice" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h1 class="text-3xl font-bold text-slate-900 dark:text-white">
                    @if (isEdit)
                    {
                        <text>Edit Invoice</text>
                    }
                    else
                    {

                        <text>New Invoice</text>
                    }
                </h1>
                <p class="text-slate-500 dark:text-slate-400">@(isEdit ? "Update invoice details" : "Create a new invoice for client")</p>
            </div>
        </div>

        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-8 shadow-sm">
            <form asp-action="@(isEdit ? "Edit" : "Create")" method="post" class="space-y-8">
                @if (isEdit)
                {
                    <input type="hidden" asp-for="Id" />
                }

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Invoice Number -->
                    <div>
                        <label class="block text-sm font-medium text-slate-600 dark:text-slate-400 mb-2">Invoice Number</label>
                        <input asp-for="InvoiceNumber"
                               class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl py-4 px-5 focus:outline-none focus:border-emerald-500 text-slate-900 dark:text-white"
                               placeholder="INV-2026-XXXX" />
                        <span asp-validation-for="InvoiceNumber" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Invoice Date -->
                    <div>
                        <label class="block text-sm font-medium text-slate-600 dark:text-slate-400 mb-2">Invoice Date</label>
                        <input asp-for="InvoiceDate" type="date"
                               class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl py-4 px-5 focus:outline-none focus:border-emerald-500 text-slate-900 dark:text-white" />
                        <span asp-validation-for="InvoiceDate" class="text-red-500 text-sm"></span>
                    </div>
                </div>

                <!-- Client -->
                <div>
                    <label class="block text-sm font-medium text-slate-600 dark:text-slate-400 mb-2">Client</label>
                    <select asp-for="ClientId"
                            class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl py-4 px-5 focus:outline-none focus:border-emerald-500 text-slate-900 dark:text-white">
                        <option value="">-- Select Client --</option>
                        <!-- Populated from Controller via ViewBag.Clients -->
                    </select>
                    <span asp-validation-for="ClientId" class="text-red-500 text-sm"></span>
                </div>

                <!-- Total Amount -->
                <div>
                    <label class="block text-sm font-medium text-slate-600 dark:text-slate-400 mb-2">Total Amount (৳)</label>
                    <div class="relative">
                        <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-400">৳</span>
                        <input asp-for="TotalAmount" type="number" step="0.01"
                               class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl py-4 pl-12 pr-5 focus:outline-none focus:border-emerald-500 text-slate-900 dark:text-white" />
                    </div>
                    <span asp-validation-for="TotalAmount" class="text-red-500 text-sm"></span>
                </div>

                <!-- Submit Buttons -->
                <div class="flex gap-4 pt-6 border-t border-slate-200 dark:border-slate-700">
                    <button type="submit"
                            class="flex-1 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold py-4 rounded-2xl transition shadow-lg shadow-emerald-500/30">
                        @if (isEdit)
                        {
                            <text>Update Invoice</text>
                        }
                        else
                        {

                            <text>Create Invoice</text>
                        }
                    </button>

                    <a href="/Invoice"
                       class="flex-1 text-center py-4 border border-slate-300 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-2xl font-medium transition">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@model AMS.Models.Case

@{
    ViewData["Title"] = "Case Details";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-300 p-8 transition-colors">
    <div class="max-w-5xl mx-auto">

        <!-- Header -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 mb-8">
            <div>
                <div class="flex items-center gap-4">
                    <span class="text-4xl">⚖️</span>
                    <div>
                        <h1 class="text-4xl font-bold text-slate-900 dark:text-white">@Model.CaseTitle</h1>
                        <p class="text-emerald-600 dark:text-emerald-400 font-mono text-xl">@Model.CaseNumber</p>
                    </div>
                </div>
            </div>

            <div class="flex gap-3">
                <a href="@Url.Action("Edit", new { id = Model.Id })"
                   class="px-6 py-3 bg-amber-600 hover:bg-amber-500 text-white rounded-2xl font-semibold flex items-center gap-2 transition">
                    <i class="fas fa-edit"></i> Edit Case
                </a>
                <a href="@Url.Action("Index")"
                   class="px-6 py-3 bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 rounded-2xl font-medium transition flex items-center gap-2">
                    <i class="fas fa-arrow-left"></i> Back to All Cases
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

            <!-- Main Info Card -->
            <div class="lg:col-span-8 space-y-6">
                <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-8">
                    <h2 class="text-2xl font-semibold mb-6 text-slate-900 dark:text-white">Case Information</h2>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Case Type</p>
                            <p class="text-xl font-medium mt-1">@Model.CaseType</p>
                        </div>
                        <div>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Status</p>
                            <div class="mt-1">
                                @{
                                    string statusClass = Model.Status switch
                                    {
                                        "Active" => "bg-emerald-500/20 text-emerald-700 dark:text-emerald-400",
                                        "Pending" => "bg-amber-500/20 text-amber-700 dark:text-amber-400",
                                        "Under Review" => "bg-blue-500/20 text-blue-700 dark:text-blue-400",
                                        "Resolved" => "bg-violet-500/20 text-violet-700 dark:text-violet-400",
                                        _ => "bg-slate-500/20 text-slate-700 dark:text-slate-400"
                                    };
                                }
                                <span class="inline-block px-6 py-2 text-sm font-semibold rounded-2xl @statusClass">
                                    @Model.Status
                                </span>
                            </div>
                        </div>
                        <div>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Filing Date</p>
                            <p class="text-xl font-medium mt-1">@Model.FilingDate.ToString("dd MMMM yyyy")</p>
                        </div>
                        <div>
                            <p class="text-sm text-slate-500 dark:text-slate-400">Revenue / Value</p>
                            <p class="text-xl font-medium mt-1 text-emerald-600 dark:text-emerald-400">৳ —</p>
                        </div>
                    </div>

                    <div class="mt-10">
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">Description</p>
                        <div class="bg-slate-50 dark:bg-slate-800 rounded-2xl p-6 text-slate-700 dark:text-slate-300 leading-relaxed">
                            @Model.Description
                        </div>
                    </div>
                </div>

                <!-- Hearings Section -->
                <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-8">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-2xl font-semibold text-slate-900 dark:text-white">Hearings</h2>
                        <a href="#" class="text-emerald-600 hover:text-emerald-500 text-sm font-medium flex items-center gap-1">
                            <i class="fas fa-plus"></i> Add Hearing
                        </a>
                    </div>
                    <p class="text-slate-500 dark:text-slate-400 italic">No hearings recorded yet.</p>
                    <!-- You can later bind @Model.Hearings here -->
                </div>
            </div>

            <!-- Sidebar -->
            <div class="lg:col-span-4 space-y-6">

                <!-- Client Info -->
                <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-8">
                    <h3 class="font-semibold text-lg mb-5 flex items-center gap-2">
                        <i class="fas fa-user"></i> Client Information
                    </h3>
                    @if (Model.Client != null)
                    {
                        <div class="flex items-center gap-4">
                            <div class="w-14 h-14 bg-slate-200 dark:bg-slate-700 rounded-2xl flex items-center justify-center text-2xl">
                                👤
                            </div>
                            <div>
                                <p class="font-semibold text-lg">@Model.Client.ClientName</p>
                                <p class="text-slate-500 dark:text-slate-400 text-sm">@Model.Client.Phone</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-slate-500">No client assigned</p>
                    }
                </div>

                <!-- Advocate Info -->
                <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-8">
                    <h3 class="font-semibold text-lg mb-5 flex items-center gap-2">
                        <i class="fas fa-user-tie"></i> Assigned Advocate
                    </h3>
                    @if (Model.Advocate != null)
                    {
                        <p class="font-semibold">@Model.Advocate.AdvocateName</p>
                    }
                    else
                    {
                        <p class="text-slate-500">No advocate assigned</p>
                    }
                </div>

                <!-- Documents -->
                <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-8">
                    <h3 class="font-semibold text-lg mb-5 flex items-center gap-2">
                        <i class="fas fa-folder-open"></i> Documents
                    </h3>
                    <p class="text-slate-500 dark:text-slate-400">0 documents attached</p>
                    <!-- Later you can loop through @Model.Documents -->
                </div>

                <!-- Quick Actions -->
                <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-8">
                    <h3 class="font-semibold text-lg mb-4">Quick Actions</h3>
                    <div class="space-y-3">
                        <button onclick="alert('Add new hearing modal will open here')"
                                class="w-full py-4 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-2xl transition flex items-center justify-center gap-3">
                            <i class="fas fa-calendar-plus"></i> Schedule Hearing
                        </button>
                        <button onclick="alert('Document upload coming soon')"
                                class="w-full py-4 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-2xl transition flex items-center justify-center gap-3">
                            <i class="fas fa-upload"></i> Upload Document
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
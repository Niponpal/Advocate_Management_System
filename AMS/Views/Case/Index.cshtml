@model IEnumerable<AMS.Models.Case>

@{
    ViewData["Title"] = "Cases";
}

<div class="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-300 p-8 transition-colors">
    <div class="max-w-7xl mx-auto space-y-10">

        <!-- Page Header -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6">
            <div>
                <h1 class="text-4xl font-bold text-slate-900 dark:text-white">All Cases</h1>
                <p class="text-slate-500 dark:text-slate-400 mt-2">Manage and track all your legal cases</p>
            </div>

            <a asp-controller="Case"
               asp-action="CreateOrEdit"
               class="px-6 py-3 bg-emerald-600 hover:bg-emerald-500 text-white transition-all rounded-2xl font-semibold flex items-center gap-3 shadow-lg shadow-emerald-500/30">
                <i class="fas fa-plus"></i>
                New Case
            </a>
        </div>

        <!-- Filters & Search -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 flex flex-wrap gap-4 items-center">
            <div class="flex-1 min-w-[280px]">
                <input type="text" id="searchInput"
                       class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 focus:border-emerald-500 rounded-2xl py-4 px-6 text-slate-700 dark:text-white placeholder-slate-500 focus:outline-none transition-colors"
                       placeholder="Search by case number, title or client...">
            </div>

            <select id="statusFilter"
                    class="bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl py-4 px-6 text-slate-700 dark:text-white focus:outline-none focus:border-emerald-500 transition-colors">
                <option value="">All Status</option>
                <option value="Active">Active</option>
                <option value="Pending">Pending</option>
                <option value="Under Review">Under Review</option>
                <option value="Resolved">Resolved</option>
            </select>

            <select id="typeFilter"
                    class="bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-2xl py-4 px-6 text-slate-700 dark:text-white focus:outline-none focus:border-emerald-500 transition-colors">
                <option value="">All Case Types</option>
                <option value="Criminal">Criminal</option>
                <option value="Civil">Civil</option>
                <option value="Family">Family</option>
                <option value="Property">Property</option>
            </select>

            <button onclick="filterCases()"
                    class="px-8 py-4 bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 transition-all rounded-2xl font-medium">
                <i class="fas fa-filter"></i> Filter
            </button>
        </div>

        <!-- Cases Table -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl overflow-hidden">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400 text-sm">
                        <th class="text-left py-6 px-8 font-medium">Case Number</th>
                        <th class="text-left py-6 px-8 font-medium">Case Title</th>
                        <th class="text-left py-6 px-8 font-medium">Client</th>
                        <th class="text-left py-6 px-8 font-medium">Type</th>
                        <th class="text-left py-6 px-8 font-medium">Filing Date</th>
                        <th class="text-left py-6 px-8 font-medium">Status</th>
                        <th class="text-left py-6 px-8 font-medium">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-800 text-slate-700 dark:text-slate-300" id="casesTable">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/70 transition-colors group">
                            <td class="py-6 px-8 font-mono text-emerald-600 dark:text-emerald-400">@item.CaseNumber</td>
                            <td class="py-6 px-8 font-medium">@item.CaseTitle</td>
                            <td class="py-6 px-8">@item.Client?.ClientName</td>
                            <td class="py-6 px-8">
                                <span class="px-4 py-1.5 text-xs font-medium rounded-2xl bg-slate-100 dark:bg-slate-800">@item.CaseType</span>
                            </td>
                            <td class="py-6 px-8">@item.FilingDate.ToString("dd MMM yyyy")</td>
                            <td class="py-6 px-8">
                                @{
                                    string statusClass = item.Status switch
                                    {
                                        "Active" => "bg-emerald-500/20 text-emerald-600 dark:text-emerald-400",
                                        "Pending" => "bg-amber-500/20 text-amber-600 dark:text-amber-400",
                                        "Under Review" => "bg-blue-500/20 text-blue-600 dark:text-blue-400",
                                        "Resolved" => "bg-violet-500/20 text-violet-600 dark:text-violet-400",
                                        _ => "bg-slate-500/20 text-slate-600 dark:text-slate-400"
                                    };
                                }
                                <span class="px-6 py-2 text-xs font-semibold rounded-2xl @statusClass">
                                    @item.Status
                                </span>
                            </td>
                            <td class="py-6 px-8">
                                <div class="flex gap-3 opacity-0 group-hover:opacity-100 transition-all">
                                    <a href="@Url.Action("Details", new { id = item.Id })"
                                       class="text-slate-400 hover:text-emerald-500 transition-colors">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", new { id = item.Id })"
                                       class="text-slate-400 hover:text-amber-500 transition-colors">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-20">
                <div class="text-6xl mb-4">📁</div>
                <p class="text-xl text-slate-500 dark:text-slate-400">No cases found</p>
            </div>
        }

    </div>
</div>

<script>
    function newCase() {
        window.location.href = '@Url.Action("Create")';
    }

    document.getElementById('searchInput').addEventListener('keyup', filterCases);

    function filterCases() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const statusFilter = document.getElementById('statusFilter').value;
        const typeFilter = document.getElementById('typeFilter').value;

        const rows = document.querySelectorAll('#casesTable tr');

        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            const statusCell = row.cells[5]?.textContent.trim();
            const typeCell = row.cells[3]?.textContent.trim();

            const matchesSearch = text.includes(searchTerm);
            const matchesStatus = !statusFilter || statusCell === statusFilter;
            const matchesType = !typeFilter || typeCell === typeFilter;

            row.style.display = (matchesSearch && matchesStatus && matchesType) ? '' : 'none';
        });
    }
</script>
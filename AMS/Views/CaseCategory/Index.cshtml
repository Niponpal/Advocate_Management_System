@model IEnumerable<AMS.Models.CaseCategory>

@{
    ViewData["Title"] = "Case Categories";
}

<div class="flex-1 overflow-auto bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-300 p-6 lg:p-8 min-h-screen">
    <div class="max-w-7xl mx-auto space-y-8">

        <!-- Page Header -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <h1 class="text-3xl font-bold tracking-tight text-slate-800 dark:text-white">Case Categories</h1>
                <p class="text-slate-500 dark:text-slate-400 mt-1">Manage all case categories used in your firm</p>
            </div>

            <a asp-controller="CaseCategory" asp-action="CreateOrEdit"
               class="px-6 py-3 bg-emerald-600 hover:bg-emerald-500 transition-all rounded-2xl font-semibold flex items-center gap-3 text-white shadow-lg shadow-emerald-500/30">
                <i class="fas fa-plus"></i>
                New Category
            </a>
        </div>

        <!-- Search & Filter -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 flex flex-col md:flex-row gap-4">
            <div class="flex-1 relative">
                <input type="text" id="searchInput"
                       class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 focus:border-emerald-500 rounded-2xl py-4 px-5 text-sm focus:outline-none transition"
                       placeholder="Search categories...">
            </div>

            <select id="statusFilter"
                    class="bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl py-4 px-5 text-sm focus:outline-none focus:border-emerald-500">
                <option value="">All Status</option>
                <option value="true">Active</option>
                <option value="false">Inactive</option>
            </select>
        </div>

        <!-- Data Table -->
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400 text-sm">
                            <th class="text-left py-6 px-8 font-medium">Category Name</th>
                            <th class="text-left py-6 px-8 font-medium">Status</th>
                            <th class="text-right py-6 px-8 font-medium">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-800" id="categoryTable">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/70 transition-all group">
                                <td class="py-6 px-8 font-medium text-slate-800 dark:text-white">@item.CategoryName</td>
                                <td class="py-6 px-8">
                                    @if (item.IsActive)
                                    {
                                        <span class="inline-flex items-center px-4 py-1.5 bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400 rounded-2xl text-xs font-semibold">
                                            <span class="w-2 h-2 bg-emerald-500 rounded-full mr-2 animate-pulse"></span>
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-4 py-1.5 bg-slate-100 dark:bg-slate-500/20 text-slate-600 dark:text-slate-400 rounded-2xl text-xs font-semibold">
                                            Inactive
                                        </span>
                                    }
                                </td>
                                <td class="py-6 px-8 text-right">
                                    <div class="flex justify-end gap-3 opacity-75 group-hover:opacity-100 transition-all">
                                        <a asp-controller="CaseCategory" asp-action="Details" asp-route-id="@item.Id"
                                           class="p-3 hover:bg-slate-100 dark:hover:bg-slate-700 rounded-xl transition-colors">
                                            <i class="fas fa-eye text-sky-500"></i>
                                        </a>
                                        <a asp-controller="CaseCategory" asp-action="CreateOrEdit" asp-route-id="@item.Id"
                                           class="p-3 hover:bg-slate-100 dark:hover:bg-slate-700 rounded-xl transition-colors">
                                            <i class="fas fa-edit text-amber-500"></i>
                                        </a>
                                        <button onclick="deleteCategory(@item.Id, '@Html.Raw(item.CategoryName)')"
                                                class="p-3 hover:bg-slate-100 dark:hover:bg-slate-700 rounded-xl transition-colors">
                                            <i class="fas fa-trash text-rose-500"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="py-20 text-center">
                    <div class="text-6xl mb-4 opacity-30">📂</div>
                    <p class="text-slate-500 dark:text-slate-400 text-lg">No case categories found.</p>
                </div>
            }
        </div>
    </div>
</div>

<script>
    // Live Search
    document.getElementById('searchInput').addEventListener('keyup', function () {
        const filter = this.value.toLowerCase();
        const rows = document.querySelectorAll('#categoryTable tr');
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(filter) ? '' : 'none';
        });
    });

    // Status Filter
    document.getElementById('statusFilter').addEventListener('change', function () {
        const filter = this.value;
        const rows = document.querySelectorAll('#categoryTable tr');
        rows.forEach(row => {
            if (!filter) { row.style.display = ''; return; }
            const isActive = row.querySelector('.bg-emerald-500\\/20') !== null;
            row.style.display = (filter === 'true' && isActive) || (filter === 'false' && !isActive) ? '' : 'none';
        });
    });

    function deleteCategory(id, name) {
        if (confirm(`Are you sure you want to delete "${name}"?`)) {
            window.location.href = `/CaseCategory/Delete/${id}`;
        }
    }
</script>
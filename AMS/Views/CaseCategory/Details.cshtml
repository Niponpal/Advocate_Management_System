@model AMS.Models.CaseCategory

@{
    ViewData["Title"] = "Category Details - " + Model?.CategoryName;
}

<div class="flex-1 overflow-auto bg-slate-50 dark:bg-slate-950 text-slate-700 dark:text-slate-300 p-6 lg:p-8">
    <div class="max-w-2xl mx-auto">

        <!-- Back Navigation -->
        <a asp-action="Index"
           class="inline-flex items-center gap-2 text-emerald-600 dark:text-emerald-400 hover:underline mb-6 font-medium">
            ← Back to Case Categories
        </a>

        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-8 shadow-sm">

            <div class="flex justify-between items-start mb-10">
                <div>
                    <h1 class="text-3xl font-bold text-slate-800 dark:text-white">@Model.CategoryName</h1>
                    <p class="text-slate-500 dark:text-slate-400 mt-1">Case Category Information</p>
                </div>

                <span class="px-6 py-3 text-sm font-semibold rounded-2xl
                    @(Model.IsActive ? "bg-emerald-100 dark:bg-emerald-500/20 text-emerald-700 dark:text-emerald-400" : "bg-slate-100 dark:bg-slate-500/20 text-slate-600 dark:text-slate-400")">
                    @(Model.IsActive ? "Active" : "Inactive")
                </span>
            </div>

            <div class="grid grid-cols-1 gap-8">
                <!-- Category Details -->
                <div class="space-y-6">
                    <div>
                        <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Category Name</p>
                        <p class="text-2xl font-semibold text-slate-800 dark:text-white">@Model.CategoryName</p>
                    </div>

                    <div>
                        <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Status</p>
                        @if (Model.IsActive)
                        {
                            <div class="inline-flex items-center gap-3 px-6 py-3 bg-emerald-100 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 rounded-2xl">
                                <span class="w-3 h-3 bg-emerald-500 rounded-full animate-pulse"></span>
                                <span class="font-semibold">Active</span>
                            </div>
                        }
                        else
                        {
                            <div class="inline-flex items-center px-6 py-3 bg-slate-100 dark:bg-slate-500/10 text-slate-600 dark:text-slate-400 rounded-2xl font-semibold">
                                Inactive
                            </div>
                        }
                    </div>

                    <div>
                        <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Category ID</p>
                        <p class="font-mono text-lg text-slate-600 dark:text-slate-400">#@Model.Id</p>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-700 flex flex-col sm:flex-row gap-4">
                <a asp-action="CreateOrEdit" asp-route-id="@Model.Id"
                   class="flex-1 bg-emerald-600 hover:bg-emerald-500 text-white py-4 text-center rounded-2xl font-semibold shadow-lg shadow-emerald-500/30 transition">
                    <i class="fas fa-edit mr-2"></i> Edit Category
                </a>

                <button onclick="deleteCategory(@Model.Id, '@Html.Raw(Model.CategoryName)')"
                        class="flex-1 border border-rose-300 dark:border-rose-700 hover:bg-rose-50 dark:hover:bg-rose-900/50 text-rose-600 dark:text-rose-400 py-4 rounded-2xl font-semibold transition">
                    <i class="fas fa-trash mr-2"></i> Delete Category
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function deleteCategory(id, name) {
        if (confirm(`Are you sure you want to permanently delete the category "${name}"?\n\nThis action cannot be undone.`)) {
            window.location.href = `/CaseCategory/Delete/${id}`;
        }
    }
</script>
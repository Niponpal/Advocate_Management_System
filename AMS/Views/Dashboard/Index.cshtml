@{
    ViewData["Title"] = "Dashboard";
}

<div class="min-h-screen bg-slate-950 text-white p-8">
    <div class="max-w-7xl mx-auto space-y-10">

        <!-- Hero Section -->
        <div class="bg-gradient-to-r from-slate-900 to-slate-800 border border-slate-700 rounded-3xl p-10 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-80 h-80 bg-emerald-500/10 rounded-full blur-3xl"></div>

            <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-8">
                <div class="flex items-center gap-4">
                    <div class="w-16 h-16 bg-emerald-600 rounded-2xl flex items-center justify-center text-3xl">⚖️</div>
                    <div>
                        <p class="text-emerald-400 text-sm font-medium tracking-widest">SENIOR ADVOCATE</p>
                        <h1 class="text-5xl font-bold mt-1">Adv. Rahim Khan</h1>
                        <p class="text-slate-400 mt-2">Managing Partner • Khan & Associates</p>
                    </div>
                </div>

                <div class="flex items-center gap-8">
                    <div class="text-right">
                        <p class="text-4xl font-semibold text-emerald-400">৳1.84Cr</p>
                        <p class="text-slate-400 text-sm">Revenue This Year • <span class="text-emerald-500">+18%</span></p>
                    </div>

                    <button onclick="newCase()"
                            class="px-8 py-4 bg-emerald-600 hover:bg-emerald-500 transition-all rounded-2xl font-semibold flex items-center gap-3 text-lg shadow-lg shadow-emerald-500/30">
                        <i class="fas fa-plus"></i>
                        New Case
                    </button>
                </div>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="bg-slate-900 border border-slate-800 rounded-3xl p-8 hover:border-emerald-500/50 transition-all group">
                <div class="flex justify-between">
                    <div>
                        <p class="text-slate-400 text-sm">Total Cases</p>
                        <p class="text-5xl font-bold mt-4">248</p>
                    </div>
                    <div class="text-4xl text-emerald-500 group-hover:scale-110 transition-transform">
                        <i class="fas fa-briefcase"></i>
                    </div>
                </div>
                <div class="mt-6 text-emerald-500 text-sm flex items-center gap-2">
                    <i class="fas fa-arrow-trend-up"></i>
                    <span>+12 this month</span>
                </div>
            </div>

            <div class="bg-slate-900 border border-slate-800 rounded-3xl p-8 hover:border-amber-500/50 transition-all group">
                <div class="flex justify-between">
                    <div>
                        <p class="text-slate-400 text-sm">Active Cases</p>
                        <p class="text-5xl font-bold mt-4">87</p>
                    </div>
                    <div class="text-4xl text-amber-500 group-hover:scale-110 transition-transform">
                        <i class="fas fa-fire"></i>
                    </div>
                </div>
                <div class="mt-6 text-amber-500 text-sm flex items-center gap-2">
                    <i class="fas fa-clock"></i>
                    <span>4 hearings this week</span>
                </div>
            </div>

            <div class="bg-slate-900 border border-slate-800 rounded-3xl p-8 hover:border-sky-500/50 transition-all group">
                <div class="flex justify-between">
                    <div>
                        <p class="text-slate-400 text-sm">Total Clients</p>
                        <p class="text-5xl font-bold mt-4">164</p>
                    </div>
                    <div class="text-4xl text-sky-500 group-hover:scale-110 transition-transform">
                        <i class="fas fa-users"></i>
                    </div>
                </div>
                <div class="mt-6 text-sky-500 text-sm flex items-center gap-2">
                    <i class="fas fa-user-plus"></i>
                    <span>+8 new clients</span>
                </div>
            </div>

            <div class="bg-slate-900 border border-slate-800 rounded-3xl p-8 hover:border-violet-500/50 transition-all group relative">
                <div class="flex justify-between">
                    <div>
                        <p class="text-slate-400 text-sm">Win Rate</p>
                        <p class="text-5xl font-bold mt-4">94%</p>
                    </div>
                    <div class="text-4xl text-violet-500 group-hover:scale-110 transition-transform">
                        <i class="fas fa-trophy"></i>
                    </div>
                </div>
                <div class="absolute bottom-8 right-8 bg-violet-500/10 text-violet-400 text-xs px-4 py-2 rounded-2xl">
                    Outstanding
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

            <!-- New Section: Case Status Breakdown -->
            <div class="lg:col-span-7 bg-slate-900 border border-slate-800 rounded-3xl p-8">
                <h3 class="text-2xl font-semibold mb-6">Case Status Breakdown</h3>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <div class="bg-slate-800 rounded-2xl p-6 text-center hover:bg-slate-700 transition-all">
                        <div class="text-4xl mb-3">🟢</div>
                        <p class="text-3xl font-bold text-emerald-400">87</p>
                        <p class="text-slate-400 mt-1">Active</p>
                    </div>
                    <div class="bg-slate-800 rounded-2xl p-6 text-center hover:bg-slate-700 transition-all">
                        <div class="text-4xl mb-3">🟡</div>
                        <p class="text-3xl font-bold text-amber-400">42</p>
                        <p class="text-slate-400 mt-1">Pending</p>
                    </div>
                    <div class="bg-slate-800 rounded-2xl p-6 text-center hover:bg-slate-700 transition-all">
                        <div class="text-4xl mb-3">🔵</div>
                        <p class="text-3xl font-bold text-blue-400">68</p>
                        <p class="text-slate-400 mt-1">Under Review</p>
                    </div>
                    <div class="bg-slate-800 rounded-2xl p-6 text-center hover:bg-slate-700 transition-all">
                        <div class="text-4xl mb-3">✅</div>
                        <p class="text-3xl font-bold text-violet-400">51</p>
                        <p class="text-slate-400 mt-1">Resolved</p>
                    </div>
                </div>
            </div>

            <!-- Upcoming Hearings -->
            <div class="lg:col-span-5 bg-slate-900 border border-slate-800 rounded-3xl p-8">
                <h3 class="text-2xl font-semibold mb-6 flex items-center gap-3">
                    <i class="fas fa-calendar-alt"></i>
                    Upcoming Hearings
                </h3>
                <div class="space-y-6">
                    <div class="flex gap-5 bg-slate-800/60 p-5 rounded-2xl hover:bg-slate-700 transition-all">
                        <div class="text-4xl">⚖️</div>
                        <div class="flex-1">
                            <p class="font-semibold">State vs Karim Ahmed</p>
                            <p class="text-slate-400 text-sm">Criminal • Session Court, Dhaka</p>
                            <p class="text-rose-400 text-sm mt-3 font-medium">Tomorrow • 10:30 AM</p>
                        </div>
                    </div>

                    <div class="flex gap-5 bg-slate-800/60 p-5 rounded-2xl hover:bg-slate-700 transition-all">
                        <div class="text-4xl">🏛️</div>
                        <div class="flex-1">
                            <p class="font-semibold">Rahman Family Property Dispute</p>
                            <p class="text-slate-400 text-sm">Civil • High Court Division</p>
                            <p class="text-slate-400 text-sm mt-3">June 04, 2026 • 02:00 PM</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Cases -->
        <div class="bg-slate-900 border border-slate-800 rounded-3xl p-8">
            <div class="flex justify-between items-center mb-8">
                <h3 class="text-2xl font-semibold">Recent Cases</h3>
                <a href="#" class="text-emerald-400 hover:text-emerald-300 transition-colors">View All Cases →</a>
            </div>

            <table class="w-full">
                <thead>
                    <tr class="text-slate-400 text-sm border-b border-slate-700">
                        <th class="pb-6 text-left">Case ID</th>
                        <th class="pb-6 text-left">Client</th>
                        <th class="pb-6 text-left">Matter</th>
                        <th class="pb-6 text-left">Status</th>
                        <th class="pb-6 text-left">Next Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800 text-slate-300">
                    <tr class="hover:bg-slate-800/50 transition">
                        <td class="py-6 font-mono">#CP-7842</td>
                        <td class="py-6">Mr. Tanvir Hassan</td>
                        <td class="py-6">Land Acquisition Dispute</td>
                        <td><span class="px-6 py-2 bg-emerald-500/20 text-emerald-400 rounded-2xl text-xs font-semibold">ACTIVE</span></td>
                        <td class="py-6">08 June 2026</td>
                    </tr>
                    <tr class="hover:bg-slate-800/50 transition">
                        <td class="py-6 font-mono">#CR-3921</td>
                        <td class="py-6">Mrs. Nusrat Jahan</td>
                        <td class="py-6">Divorce & Alimony</td>
                        <td><span class="px-6 py-2 bg-amber-500/20 text-amber-400 rounded-2xl text-xs font-semibold">PENDING</span></td>
                        <td class="py-6">12 June 2026</td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>
</div>

<script>
    function newCase() {
        alert("New Case form will open here");
    }
</script>
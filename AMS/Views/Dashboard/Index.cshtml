<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AdvocatePro • Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

    <style>
        body { font-family: 'Segoe UI', system-ui, sans-serif; }
        .card-hover { transition: all 0.3s ease; }
        .card-hover:hover { transform: translateY(-4px); box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1); }
    </style>
</head>
<body class="bg-slate-50 text-slate-700">

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <div class="w-72 bg-white border-r border-slate-200 flex flex-col">
            <div class="p-6 border-b flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-700 rounded-xl flex items-center justify-center text-white font-bold text-2xl">AP</div>
                <div>
                    <h1 class="text-2xl font-bold text-slate-800">AdvocatePro</h1>
                    <p class="text-xs text-slate-500">Law Firm Management</p>
                </div>
            </div>

            <nav class="flex-1 p-4 overflow-y-auto">
                <ul class="space-y-1">
                    <li><a href="#" class="flex items-center gap-3 px-4 py-3 bg-blue-50 text-blue-700 rounded-xl font-medium"><i class="fas fa-home"></i> Dashboard</a></li>
                    <li><a href="#" class="flex items-center gap-3 px-4 py-3 hover:bg-slate-100 rounded-xl"><i class="fas fa-user-tie"></i> Advocates</a></li>
                    <li><a href="#" class="flex items-center gap-3 px-4 py-3 hover:bg-slate-100 rounded-xl"><i class="fas fa-briefcase"></i> Cases</a></li>
                    <li><a href="#" class="flex items-center gap-3 px-4 py-3 hover:bg-slate-100 rounded-xl"><i class="fas fa-users"></i> Clients</a></li>
                    <li><a href="#" class="flex items-center gap-3 px-4 py-3 hover:bg-slate-100 rounded-xl"><i class="fas fa-calendar"></i> Hearings</a></li>
                    <li><a href="#" class="flex items-center gap-3 px-4 py-3 hover:bg-slate-100 rounded-xl"><i class="fas fa-folder"></i> Documents</a></li>
                    <li><a href="#" class="flex items-center gap-3 px-4 py-3 hover:bg-slate-100 rounded-xl"><i class="fas fa-file-invoice"></i> Billing</a></li>
                    <li><a href="#" class="flex items-center gap-3 px-4 py-3 hover:bg-slate-100 rounded-xl"><i class="fas fa-chart-bar"></i> Reports</a></li>
                </ul>
            </nav>

            <div class="p-4 border-t">
                <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-2xl">
                    <img src="https://i.pravatar.cc/48?u=adv" class="w-10 h-10 rounded-full">
                    <div>
                        <p class="font-semibold">Adv. Rahim Khan</p>
                        <p class="text-sm text-slate-500">Senior Advocate</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Top Navbar -->
            <header class="bg-white border-b px-8 py-5 flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <h2 class="text-3xl font-bold text-slate-800">Dashboard Overview</h2>
                </div>

                <div class="flex items-center gap-6">
                    <div class="relative">
                        <input type="text" id="search"
                               class="w-80 bg-slate-100 border border-transparent focus:border-blue-300 rounded-2xl py-3 px-5 text-sm focus:outline-none"
                               placeholder="Search cases, advocates, clients...">
                    </div>

                    <button class="relative p-3 hover:bg-slate-100 rounded-2xl">
                        <i class="fas fa-bell text-xl"></i>
                        <span class="absolute top-2 right-2 w-5 h-5 bg-red-500 text-white text-xs rounded-full flex items-center justify-center">7</span>
                    </button>

                    <div class="flex items-center gap-3">
                        <div class="text-right">
                            <p class="font-medium">Rahim Khan</p>
                            <p class="text-xs text-emerald-600">Online</p>
                        </div>
                        <img src="https://i.pravatar.cc/48?u=rahim" class="w-10 h-10 rounded-2xl border-2 border-white shadow">
                    </div>
                </div>
            </header>

            <!-- Dashboard Body -->
            <div class="flex-1 overflow-auto p-8 space-y-8">

                <!-- KPI Cards -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="bg-white rounded-3xl p-6 shadow-sm card-hover">
                        <div class="flex justify-between items-start">
                            <div>
                                <p class="text-slate-500 text-sm">Total Advocates</p>
                                <p class="text-4xl font-bold text-slate-800 mt-2">248</p>
                            </div>
                            <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center text-2xl">
                                👨‍⚖️
                            </div>
                        </div>
                        <p class="text-emerald-600 text-sm mt-4 flex items-center gap-1">
                            <i class="fas fa-arrow-up"></i> +12 this month
                        </p>
                    </div>

                    <div class="bg-white rounded-3xl p-6 shadow-sm card-hover">
                        <div class="flex justify-between items-start">
                            <div>
                                <p class="text-slate-500 text-sm">Active Cases</p>
                                <p class="text-4xl font-bold text-slate-800 mt-2">184</p>
                            </div>
                            <div class="w-12 h-12 bg-amber-100 text-amber-600 rounded-2xl flex items-center justify-center text-2xl">
                                📋
                            </div>
                        </div>
                        <p class="text-emerald-600 text-sm mt-4 flex items-center gap-1">
                            <i class="fas fa-arrow-up"></i> +8 this month
                        </p>
                    </div>

                    <div class="bg-white rounded-3xl p-6 shadow-sm card-hover">
                        <div class="flex justify-between items-start">
                            <div>
                                <p class="text-slate-500 text-sm">Upcoming Hearings</p>
                                <p class="text-4xl font-bold text-slate-800 mt-2">37</p>
                            </div>
                            <div class="w-12 h-12 bg-purple-100 text-purple-600 rounded-2xl flex items-center justify-center text-2xl">
                                ⚖️
                            </div>
                        </div>
                        <p class="text-red-600 text-sm mt-4 flex items-center gap-1">
                            <i class="fas fa-arrow-down"></i> -3 from last week
                        </p>
                    </div>

                    <div class="bg-white rounded-3xl p-6 shadow-sm card-hover">
                        <div class="flex justify-between items-start">
                            <div>
                                <p class="text-slate-500 text-sm">Monthly Revenue</p>
                                <p class="text-4xl font-bold text-slate-800 mt-2">৳18.45L</p>
                            </div>
                            <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-2xl flex items-center justify-center text-2xl">
                                💰
                            </div>
                        </div>
                        <p class="text-emerald-600 text-sm mt-4 flex items-center gap-1">
                            <i class="fas fa-arrow-up"></i> 14% growth
                        </p>
                    </div>
                </div>

                <!-- Charts & Tables -->
                <div class="grid grid-cols-1 lg:grid-cols-7 gap-6">

                    <!-- Recent Cases -->
                    <div class="lg:col-span-4 bg-white rounded-3xl p-6 shadow-sm">
                        <div class="flex justify-between items-center mb-6">
                            <h3 class="font-semibold text-lg">Recent Cases</h3>
                            <button class="text-blue-600 hover:text-blue-700 text-sm font-medium">View All →</button>
                        </div>

                        <table class="w-full">
                            <thead>
                                <tr class="border-b text-left text-sm text-slate-500">
                                    <th class="pb-4">Case ID</th>
                                    <th class="pb-4">Client</th>
                                    <th class="pb-4">Advocate</th>
                                    <th class="pb-4">Type</th>
                                    <th class="pb-4">Status</th>
                                    <th class="pb-4 text-right">Next Hearing</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm">
                                <tr class="border-b hover:bg-slate-50">
                                    <td class="py-4 font-medium">#C-39482</td>
                                    <td>Mr. Karim Hossain</td>
                                    <td>Adv. Rahim Khan</td>
                                    <td>Criminal</td>
                                    <td><span class="bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full text-xs">Running</span></td>
                                    <td class="text-right">12 Jun 2026</td>
                                </tr>
                                <tr class="border-b hover:bg-slate-50">
                                    <td class="py-4 font-medium">#C-39481</td>
                                    <td>ABC Corporation</td>
                                    <td>Adv. Fatima Begum</td>
                                    <td>Corporate</td>
                                    <td><span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-xs">Pending</span></td>
                                    <td class="text-right">15 Jun 2026</td>
                                </tr>
                                <tr class="hover:bg-slate-50">
                                    <td class="py-4 font-medium">#C-39480</td>
                                    <td>Mrs. Salma Akter</td>
                                    <td>Adv. Rahim Khan</td>
                                    <td>Family</td>
                                    <td><span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-xs">Hearing</span></td>
                                    <td class="text-right">08 Jun 2026</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Charts -->
                    <div class="lg:col-span-3 space-y-6">

                        <!-- Case Status -->
                        <div class="bg-white rounded-3xl p-6 shadow-sm">
                            <h3 class="font-semibold mb-4">Case Status Distribution</h3>
                            <canvas id="caseChart" height="160"></canvas>
                        </div>

                        <!-- Performance -->
                        <div class="bg-white rounded-3xl p-6 shadow-sm">
                            <h3 class="font-semibold mb-4">Top Advocates</h3>
                            <canvas id="advocateChart" height="160"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Upcoming Hearings -->
                <div class="bg-white rounded-3xl p-6 shadow-sm">
                    <h3 class="font-semibold text-lg mb-5">Upcoming Hearings This Week</h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="border rounded-2xl p-5 hover:border-blue-300 transition">
                            <p class="text-sm text-slate-500">Tomorrow • 10:30 AM</p>
                            <p class="font-medium mt-1">State vs. Mr. Karim Hossain</p>
                            <p class="text-sm text-slate-500 mt-2">Dhaka Metropolitan Court • Room 12</p>
                            <p class="text-xs mt-3 text-blue-600 font-medium">Adv. Rahim Khan</p>
                        </div>
                        <div class="border rounded-2xl p-5 hover:border-blue-300 transition">
                            <p class="text-sm text-slate-500">04 Jun 2026 • 02:00 PM</p>
                            <p class="font-medium mt-1">ABC Ltd vs. Tax Authority</p>
                            <p class="text-sm text-slate-500 mt-2">High Court Division</p>
                            <p class="text-xs mt-3 text-blue-600 font-medium">Adv. Fatima Begum</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Tailwind Script
        tailwind.config = {
          content: [],
          theme: { extend: {} }
        }

        // Case Status Chart
        new Chart(document.getElementById('caseChart'), {
          type: 'doughnut',
          data: {
            labels: ['Running', 'Settled', 'Pending', 'Dismissed'],
            datasets: [{
              data: [45, 30, 18, 7],
              backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#ef4444'],
              borderWidth: 0
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { position: 'bottom' }
            }
          }
        });

        // Advocate Performance Chart
        new Chart(document.getElementById('advocateChart'), {
          type: 'bar',
          data: {
            labels: ['Rahim Khan', 'Fatima Begum', 'Sohail Ahmed', 'Nadia Islam'],
            datasets: [{
              label: 'Cases Won',
              data: [42, 38, 29, 25],
              backgroundColor: '#1e40af',
              borderRadius: 8
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } }
          }
        });
    </script>
</body>
</html>